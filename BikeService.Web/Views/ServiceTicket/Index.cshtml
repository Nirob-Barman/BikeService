@model List<BikeService.Application.DTOs.ServiceTicket.ServiceTicketDto>
@using BikeService.Domain.Enums
@{
    ViewData["Title"] = "My Service Tickets";
}

<div class="cst-page-head">
    <div class="cst-page-head-left">
        <h2>My Service Tickets</h2>
        @if (Model.Any())
        {
            <span class="cst-badge cst-badge-pending">@Model.Count ticket@(Model.Count == 1 ? "" : "s")</span>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="cst-card">
        <div class="cst-empty">
            <div class="cst-empty-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                </svg>
            </div>
            <h4>No service tickets yet</h4>
            <p>Book an appointment to get started — we'll open a ticket once your bike is checked in.</p>
            <a asp-controller="Appointment" asp-action="Create" class="cst-btn cst-btn-primary">Book an Appointment</a>
        </div>
    </div>
}
else
{
    <div class="cst-card">
        <div class="cst-table-wrap">
            <table class="cst-table">
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Bike</th>
                        <th>Mechanic</th>
                        <th>Status</th>
                        <th>Est. Completion</th>
                        <th class="r"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model.OrderByDescending(t => t.CreatedAt))
                    {
                        <tr>
                            <td class="muted">#@ticket.Id</td>
                            <td class="bold">@ticket.BikeSummary</td>
                            <td>@(ticket.MechanicName ?? "—")</td>
                            <td>
                                @{
                                    var (bCls, bLbl) = ticket.Status switch
                                    {
                                        ServiceTicketStatus.Pending        => ("cst-badge-pending",  "Pending"),
                                        ServiceTicketStatus.Diagnosed      => ("cst-badge-info",     "Diagnosed"),
                                        ServiceTicketStatus.InProgress     => ("cst-badge-warning",  "In Progress"),
                                        ServiceTicketStatus.QualityCheck   => ("cst-badge-primary",  "Quality Check"),
                                        ServiceTicketStatus.ReadyForPickup => ("cst-badge-success",  "Ready for Pickup"),
                                        ServiceTicketStatus.Delivered      => ("cst-badge-dark",     "Delivered"),
                                        ServiceTicketStatus.Cancelled      => ("cst-badge-danger",   "Cancelled"),
                                        _                                  => ("cst-badge-pending",  ticket.StatusLabel)
                                    };
                                }
                                <span class="cst-badge @bCls">@bLbl</span>
                                @if (ticket.IsOverdue)
                                {
                                    <span class="cst-badge cst-badge-danger" style="margin-left:.3rem;">Overdue</span>
                                }
                            </td>
                            <td class="muted">@(ticket.EstimatedCompletionDate?.ToString("MMM d, yyyy") ?? "—")</td>
                            <td class="r">
                                <a asp-action="Detail" asp-route-id="@ticket.Id" class="cst-btn cst-btn-outline cst-btn-sm">Track &rarr;</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
