@model List<BikeService.Application.DTOs.LeaveRequest.LeaveRequestDto>
@using BikeService.Domain.Enums
@{
    ViewData["Title"] = "Leave Requests";
}

<div class="adm-page-head">
    <div>
        <h1 class="adm-page-head-title">Leave Requests</h1>
        <p class="adm-page-head-sub">Review and approve mechanic leave submissions</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="adm-card">
        <div class="adm-card-body">
            <div class="adm-empty">
                <div class="adm-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                    </svg>
                </div>
                <p class="adm-empty-title">No leave requests</p>
                <p class="adm-empty-sub">Mechanic leave requests will appear here once submitted.</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="adm-card">
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Mechanic</th>
                        <th>Type</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td style="color:var(--muted);font-size:.8125rem;">@r.Id</td>
                            <td style="font-weight:500;">@r.MechanicName</td>
                            <td>@r.Type</td>
                            <td>@r.FromDate.ToString("MMM d, yyyy")</td>
                            <td>@r.ToDate.ToString("MMM d, yyyy")</td>
                            <td>@r.TotalDays</td>
                            <td>
                                @{
                                    var badgeCls = r.Status switch
                                    {
                                        LeaveRequestStatus.Pending  => "warning",
                                        LeaveRequestStatus.Approved => "success",
                                        LeaveRequestStatus.Rejected => "danger",
                                        _                           => "neutral",
                                    };
                                }
                                <span class="adm-badge @badgeCls">@r.Status</span>
                            </td>
                            <td style="color:var(--muted);font-size:.8125rem;">@r.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td>
                                <a asp-action="Detail" asp-route-id="@r.Id" class="adm-btn adm-btn-secondary adm-btn-sm">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
