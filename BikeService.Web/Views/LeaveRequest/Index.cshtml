@model List<BikeService.Application.DTOs.LeaveRequest.LeaveRequestDto>
@using BikeService.Domain.Enums
@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Leave Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Leave Requests</h4>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No leave requests found.</div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Mechanic</th>
                        <th>Type</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="text-muted small">@r.Id</td>
                            <td class="fw-medium">@r.MechanicName</td>
                            <td>@r.Type</td>
                            <td>@r.FromDate.ToString("MMM d, yyyy")</td>
                            <td>@r.ToDate.ToString("MMM d, yyyy")</td>
                            <td>@r.TotalDays</td>
                            <td>
                                @{
                                    var badgeClass = r.Status switch
                                    {
                                        LeaveRequestStatus.Pending  => "bg-warning text-dark",
                                        LeaveRequestStatus.Approved => "bg-success",
                                        LeaveRequestStatus.Rejected => "bg-danger",
                                        _                           => "bg-secondary",
                                    };
                                }
                                <span class="badge @badgeClass">@r.Status</span>
                            </td>
                            <td class="text-muted small">@r.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td>
                                <a asp-action="Detail" asp-route-id="@r.Id"
                                   class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
