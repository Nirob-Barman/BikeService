@model BikeService.Web.ViewModels.Account.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/Auth/_AuthLayout.cshtml";
}

<h1 class="auth-title">Create your account</h1>
<p class="auth-sub">Join BikeService and manage your bike repairs</p>

<form asp-action="Register" method="post" id="regForm">

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

    <div class="row g-3 mb-0">
        <div class="col-6">
            <div class="mb-3">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" placeholder="John"
                       autofocus autocomplete="given-name" />
                <span asp-validation-for="FirstName" class="field-validation-error"></span>
            </div>
        </div>
        <div class="col-6">
            <div class="mb-3">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" placeholder="Doe"
                       autocomplete="family-name" />
                <span asp-validation-for="LastName" class="field-validation-error"></span>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" placeholder="you@example.com"
               autocomplete="email" type="email" />
        <span asp-validation-for="Email" class="field-validation-error"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <div class="pw-wrap">
            <input asp-for="Password" class="form-control" placeholder="Min. 6 characters"
                   autocomplete="new-password" id="regPw"
                   oninput="pwStrength(this.value,'strFill','strTxt')" />
            <button type="button" class="pw-toggle" onclick="pwToggle('regPw',this)" aria-label="Show password">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
            </button>
        </div>
        <div class="strength-row">
            <div class="strength-track"><div class="strength-fill" id="strFill"></div></div>
            <span class="strength-text" id="strTxt"></span>
        </div>
        <span asp-validation-for="Password" class="field-validation-error"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <div class="pw-wrap">
            <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat your password"
                   autocomplete="new-password" id="regCpw" />
            <button type="button" class="pw-toggle" onclick="pwToggle('regCpw',this)" aria-label="Show password">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Address" class="form-label">
            Address
            <span style="color:var(--muted);font-weight:400;font-size:.75rem;"> — optional</span>
        </label>
        <input asp-for="Address" class="form-control" placeholder="123 Main St, City"
               autocomplete="street-address" />
        <span asp-validation-for="Address" class="field-validation-error"></span>
    </div>

    <button type="submit" class="btn-auth" id="regBtn">
        <span class="spin"></span>
        <span class="lbl">Create Account</span>
    </button>
</form>

<p class="auth-alt">Already have an account? <a asp-controller="Account" asp-action="Login">Sign in</a></p>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        bindSubmitLoading('regForm', 'regBtn');
    </script>
}
