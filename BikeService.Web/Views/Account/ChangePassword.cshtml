@model BikeService.Web.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    :root {
        --p:       #5B4FE9;
        --p-dark:  #4338CA;
        --p-light: #EEF2FF;
        --p-ring:  rgba(91,79,233,.15);
        --border:  #E2E8F0;
        --muted:   #64748B;
        --text:    #0F172A;
        --err:     #EF4444;
        --err-bg:  #FEF2F2;
        --err-ring:rgba(239,68,68,.15);
        --radius:  12px;
        --radius-sm: 8px;
        --font:    'Inter', system-ui, -apple-system, sans-serif;
        --t:       180ms ease;
    }
    body { background: #F8FAFC; font-family: var(--font); }

    .cpw-wrap {
        max-width: 480px;
        margin: 2.5rem auto 3rem;
        padding: 0 1rem;
    }

    /* ── Breadcrumb / back ── */
    .cpw-back {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-size: .8375rem;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        margin-bottom: 1.5rem;
        transition: color var(--t);
    }
    .cpw-back:hover { color: var(--p); }

    /* ── Title ── */
    .cpw-title {
        font-size: 1.375rem;
        font-weight: 700;
        letter-spacing: -.03em;
        color: var(--text);
        margin-bottom: .25rem;
    }
    .cpw-sub {
        font-size: .875rem;
        color: var(--muted);
        margin-bottom: 1.75rem;
    }

    /* ── Card ── */
    .cpw-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 2rem;
    }

    /* ── Form ── */
    .form-label {
        font-size: .8125rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: .35rem;
        display: block;
    }
    .form-control {
        height: 42px;
        padding: 0 .875rem;
        font-size: .9rem;
        font-family: var(--font);
        color: var(--text);
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        transition: border-color var(--t), box-shadow var(--t);
    }
    .form-control:focus {
        border-color: var(--p);
        box-shadow: 0 0 0 3px var(--p-ring);
        outline: none;
    }
    .form-control.input-validation-error {
        border-color: var(--err);
    }
    .form-control.input-validation-error:focus {
        box-shadow: 0 0 0 3px var(--err-ring);
    }
    .field-validation-error,
    .text-danger { color: var(--err) !important; font-size: .78rem; }

    /* ── Password wrapper ── */
    .pw-wrap { position: relative; }
    .pw-wrap .form-control { padding-right: 2.75rem; width: 100%; }
    .pw-toggle {
        position: absolute;
        right: .75rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        color: var(--muted);
        display: flex;
        align-items: center;
        transition: color var(--t);
        line-height: 0;
    }
    .pw-toggle:hover { color: var(--text); }

    /* ── Strength ── */
    .strength-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-top: .4rem;
    }
    .strength-track {
        flex: 1;
        height: 3px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
    }
    .strength-fill {
        height: 100%;
        width: 0;
        border-radius: 2px;
        transition: width .3s ease, background .3s ease;
    }
    .strength-text {
        font-size: .72rem;
        font-weight: 600;
        min-width: 3.2rem;
        text-align: right;
    }

    /* ── Divider ── */
    .section-divider {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin: 1.25rem 0;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--muted);
    }
    .section-divider::before,
    .section-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
    }

    /* ── Button ── */
    .btn-update {
        width: 100%;
        height: 42px;
        background: var(--p);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-family: var(--font);
        font-size: .9rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        transition: background var(--t), box-shadow var(--t), transform var(--t);
        letter-spacing: -.01em;
    }
    .btn-update:hover:not(:disabled) {
        background: var(--p-dark);
        box-shadow: 0 4px 14px rgba(91,79,233,.3);
        transform: translateY(-1px);
    }
    .btn-update:active:not(:disabled) { transform: translateY(0); }
    .btn-update:disabled { opacity: .65; cursor: not-allowed; }
    .btn-update .spin {
        display: none;
        width: 16px; height: 16px;
        border: 2px solid rgba(255,255,255,.35);
        border-top-color: #fff;
        border-radius: 50%;
        animation: bspin .55s linear infinite;
    }
    .btn-update.loading .spin { display: block; }
    .btn-update.loading .lbl { opacity: 0; position: absolute; }
    @@keyframes bspin { to { transform: rotate(360deg); } }

    /* ── Tips box ── */
    .tips-box {
        background: var(--p-light);
        border: 1px solid rgba(91,79,233,.18);
        border-radius: var(--radius-sm);
        padding: .875rem 1rem;
        margin-bottom: 1.5rem;
    }
    .tips-box p {
        font-size: .8rem;
        font-weight: 600;
        color: var(--p);
        margin-bottom: .4rem;
    }
    .tips-box ul {
        list-style: none;
        padding: 0;
        margin: 0;
        font-size: .775rem;
        color: #4338CA;
        display: flex;
        flex-direction: column;
        gap: .2rem;
    }
    .tips-box ul li::before { content: '·  '; }
</style>
}

<div class="cpw-wrap">

    <a asp-action="Profile" class="cpw-back">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Back to Profile
    </a>

    <h1 class="cpw-title">Change Password</h1>
    <p class="cpw-sub">Choose a strong, unique password you don't use elsewhere</p>

    <div class="tips-box">
        <p>Strong password tips</p>
        <ul>
            <li>At least 8 characters long</li>
            <li>Mix uppercase, numbers and symbols</li>
            <li>Don't reuse passwords from other sites</li>
        </ul>
    </div>

    <div class="cpw-card">
        <form method="post" asp-action="ChangePassword" id="cpwForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3" role="alert"></div>

            <div class="mb-4">
                <label asp-for="CurrentPassword" class="form-label"></label>
                <div class="pw-wrap">
                    <input asp-for="CurrentPassword" class="form-control"
                           autocomplete="current-password" id="curPw"
                           placeholder="Your current password" />
                    <button type="button" class="pw-toggle" onclick="cpwToggle('curPw',this)" aria-label="Show password">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
            </div>

            <div class="section-divider">New Password</div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <div class="pw-wrap">
                    <input asp-for="NewPassword" class="form-control"
                           autocomplete="new-password" id="newPw"
                           placeholder="Min. 6 characters"
                           oninput="cpwStrength(this.value)" />
                    <button type="button" class="pw-toggle" onclick="cpwToggle('newPw',this)" aria-label="Show password">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div class="strength-row">
                    <div class="strength-track"><div class="strength-fill" id="cpwFill"></div></div>
                    <span class="strength-text" id="cpwTxt"></span>
                </div>
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <div class="pw-wrap">
                    <input asp-for="ConfirmPassword" class="form-control"
                           autocomplete="new-password" id="cnfPw"
                           placeholder="Repeat new password" />
                    <button type="button" class="pw-toggle" onclick="cpwToggle('cnfPw',this)" aria-label="Show password">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn-update" id="cpwBtn">
                <span class="spin"></span>
                <span class="lbl">Update Password</span>
            </button>
        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function cpwToggle(id, btn) {
            var inp = document.getElementById(id);
            var showing = inp.type === 'text';
            inp.type = showing ? 'password' : 'text';
            btn.querySelector('svg').innerHTML = showing
                ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
                : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
        }

        function cpwStrength(val) {
            var fill = document.getElementById('cpwFill');
            var lbl  = document.getElementById('cpwTxt');
            if (!fill || !lbl) return;
            if (!val) { fill.style.width = '0'; lbl.textContent = ''; return; }
            var s = 0;
            if (val.length >= 6)  s++;
            if (val.length >= 10) s++;
            if (/[A-Z]/.test(val)) s++;
            if (/[0-9]/.test(val)) s++;
            if (/[^A-Za-z0-9]/.test(val)) s++;
            var map = [
                {w:'20%',c:'#EF4444',t:'Weak'},
                {w:'40%',c:'#F97316',t:'Fair'},
                {w:'60%',c:'#EAB308',t:'Good'},
                {w:'80%',c:'#22C55E',t:'Strong'},
                {w:'100%',c:'#16A34A',t:'Great!'},
            ];
            var cfg = map[Math.min(s - 1, 4)] || map[0];
            fill.style.width      = cfg.w;
            fill.style.background = cfg.c;
            lbl.textContent       = cfg.t;
            lbl.style.color       = cfg.c;
        }

        (function () {
            var form = document.getElementById('cpwForm');
            var btn  = document.getElementById('cpwBtn');
            if (form && btn) {
                form.addEventListener('submit', function () {
                    btn.classList.add('loading');
                    btn.disabled = true;
                });
            }
        })();
    </script>
}
