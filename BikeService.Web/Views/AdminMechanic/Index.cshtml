@model List<BikeService.Application.DTOs.Mechanic.MechanicDto>
@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Mechanics";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Mechanics</h4>
    <a asp-controller="AdminMechanic" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Mechanic
    </a>
</div>

@Html.AntiForgeryToken()

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <p class="mb-0">No mechanics found. <a asp-controller="AdminMechanic" asp-action="Create">Add one now.</a></p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Full Name</th>
                            <th>Specialty</th>
                            <th>Availability</th>
                            <th>Linked User</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td class="fw-medium">@item.FullName</td>
                                <td class="text-muted">@(item.Specialty ?? "—")</td>
                                <td>
                                    @if (item.IsAvailable)
                                    {
                                        <span class="badge bg-success">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Unavailable</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.UserId))
                                    {
                                        <span class="badge bg-info text-dark font-monospace small" title="@item.UserId">
                                            @(item.UserId.Length > 12 ? item.UserId[..12] + "…" : item.UserId)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-muted small">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-end">
                                    <a asp-controller="AdminMechanic" asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary me-1">Edit</a>

                                    <form asp-controller="AdminMechanic" asp-action="Toggle" asp-route-id="@item.Id"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(item.IsAvailable ? "btn-outline-warning" : "btn-outline-success") me-1">
                                            @(item.IsAvailable ? "Mark Busy" : "Mark Available")
                                        </button>
                                    </form>

                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="confirmDelete('@Url.Action("Delete", "AdminMechanic", new { id = item.Id })')">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
function confirmDelete(url) {
    Swal.fire({
        title: 'Delete Mechanic?',
        text: 'This cannot be undone.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'Delete'
    }).then(r => {
        if (r.isConfirmed) {
            var f = document.createElement('form');
            f.method = 'POST';
            f.action = url;
            var t = document.createElement('input');
            t.type = 'hidden';
            t.name = '__RequestVerificationToken';
            t.value = document.querySelector('input[name=__RequestVerificationToken]')?.value || '';
            f.appendChild(t);
            document.body.appendChild(f);
            f.submit();
        }
    });
}
</script>
}
