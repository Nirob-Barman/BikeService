@model BikeService.Web.ViewModels.LeaveRequest.LeaveRequestFormViewModel
@using BikeService.Domain.Enums
@{
    Layout = "~/Views/Shared/_MechanicLayout.cshtml";
    ViewData["Title"] = "Request Leave";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Leave" class="btn btn-sm btn-outline-secondary">&larr; My Leave</a>
    <div>
        <h4 class="fw-semibold mb-0">New Leave Request</h4>
        <p class="text-muted small mb-0">Submit a request for time off</p>
    </div>
</div>

<div style="max-width:520px;">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="LeaveCreate" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Type" class="form-label fw-medium small"></label>
                    <select asp-for="Type" class="form-select"
                            asp-items="Html.GetEnumSelectList<LeaveType>()"></select>
                    <span asp-validation-for="Type" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="FromDate" class="form-label fw-medium small"></label>
                        <input asp-for="FromDate" type="date" class="form-control"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="FromDate" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="ToDate" class="form-label fw-medium small"></label>
                        <input asp-for="ToDate" type="date" class="form-control"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="ToDate" class="text-danger small"></span>
                    </div>
                </div>

                <div id="daysPreview" class="alert alert-light border small py-2 mb-3 d-none">
                    Duration: <span id="daysCount" class="fw-semibold"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Reason" class="form-label fw-medium small"></label>
                    <textarea asp-for="Reason" class="form-control" rows="3"
                              placeholder="Optional — briefly explain your reason"></textarea>
                    <span asp-validation-for="Reason" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn px-4 text-white" style="background:#0f4c35;">
                        Submit Request
                    </button>
                    <a asp-action="Leave" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <div class="mt-3 small text-muted px-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" class="me-1" viewBox="0 0 16 16">
            <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
        </svg>
        Start date must be today or a future date. Overlapping requests are not allowed.
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        const fromInput = document.getElementById('FromDate');
        const toInput   = document.getElementById('ToDate');
        const preview   = document.getElementById('daysPreview');
        const count     = document.getElementById('daysCount');

        function updatePreview() {
            const f = new Date(fromInput.value);
            const t = new Date(toInput.value);
            if (!fromInput.value || !toInput.value || t < f) {
                preview.classList.add('d-none');
                return;
            }
            const days = Math.round((t - f) / 86400000) + 1;
            count.textContent = days + ' day' + (days !== 1 ? 's' : '');
            preview.classList.remove('d-none');

            // Keep toDate min in sync
            toInput.min = fromInput.value;
        }

        fromInput?.addEventListener('change', updatePreview);
        toInput?.addEventListener('change', updatePreview);
        updatePreview();
    </script>
}
