@using BikeService.Web.ViewModels.Mechanic
@using BikeService.Domain.Enums
@using System.Security.Claims
@model MechanicTicketDetailViewModel
@{
    Layout = "~/Views/Shared/_MechanicLayout.cshtml";
    ViewData["Title"] = $"Ticket #{Model.Ticket.Id}";
    var ticket = Model.Ticket;

    string StatusColor(ServiceTicketStatus s) => s switch
    {
        ServiceTicketStatus.Pending        => "secondary",
        ServiceTicketStatus.Diagnosed      => "info",
        ServiceTicketStatus.InProgress     => "primary",
        ServiceTicketStatus.QualityCheck   => "warning",
        ServiceTicketStatus.ReadyForPickup => "success",
        ServiceTicketStatus.Delivered      => "dark",
        ServiceTicketStatus.Cancelled      => "danger",
        _                                  => "secondary"
    };

    // Status progress steps
    var steps = new[] {
        ServiceTicketStatus.Pending,
        ServiceTicketStatus.Diagnosed,
        ServiceTicketStatus.InProgress,
        ServiceTicketStatus.QualityCheck,
        ServiceTicketStatus.ReadyForPickup,
        ServiceTicketStatus.Delivered
    };
    int currentIdx = Array.IndexOf(steps, ticket.Status);
}

@* ── Header ── *@
<div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
    <a asp-action="Tickets" class="btn btn-sm btn-outline-secondary">&larr; My Tickets</a>
    <div class="flex-grow-1">
        <h5 class="fw-semibold mb-0">
            Ticket #@ticket.Id
            <span class="text-muted fw-normal fs-6 ms-1">— @ticket.BikeSummary</span>
        </h5>
    </div>
    <span class="badge bg-@StatusColor(ticket.Status) fs-6">@ticket.StatusLabel</span>
    @if (ticket.IsOverdue) { <span class="badge bg-danger">Overdue</span> }
</div>

@* ── Progress bar ── *@
@if (ticket.Status != ServiceTicketStatus.Cancelled)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <div class="d-flex align-items-center justify-content-between position-relative">
                <div class="position-absolute top-50 start-0 w-100 translate-middle-y"
                     style="height:2px;background:#dee2e6;z-index:0;"></div>
                @for (int i = 0; i < steps.Length; i++)
                {
                    var done    = i <= currentIdx;
                    var current = i == currentIdx;
                    <div class="d-flex flex-column align-items-center position-relative" style="z-index:1;flex:1;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                             style="width:28px;height:28px;font-size:.7rem;
                                    background:@(done ? "#0f4c35" : "#dee2e6");
                                    color:@(done ? "#fff" : "#adb5bd");
                                    border:2px solid @(current ? "#0f4c35" : (done ? "#0f4c35" : "#dee2e6"));">
                            @if (done && !current) { <text>&#10003;</text> }
                            else { <text>@(i+1)</text> }
                        </div>
                        <span class="mt-1 text-center" style="font-size:.65rem;color:@(done ? "#0f4c35" : "#adb5bd");max-width:64px;line-height:1.2;">
                            @steps[i].ToString()
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="row g-4">

    @* ── Left column ── *@
    <div class="col-lg-8">

        @* Advance status *@
        @if (Model.NextStatus.HasValue && ticket.Status != ServiceTicketStatus.Cancelled)
        {
            <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #0f4c35 !important;">
                <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div>
                        <span class="fw-semibold small">Next step:</span>
                        <span class="badge bg-@StatusColor(Model.NextStatus.Value) ms-1">@Model.NextStatus.Value</span>
                    </div>
                    <form asp-action="AdvanceStatus" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@ticket.Id" />
                        <input type="hidden" name="newStatus" value="@((int)Model.NextStatus.Value)" />
                        <button type="submit" class="btn btn-sm px-4 text-white" style="background:#0f4c35;">
                            Mark as @Model.NextStatus.Value
                        </button>
                    </form>
                </div>
            </div>
        }

        @* Service items *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                <span>Service Items</span>
                <span class="text-muted small fw-normal">@ticket.Items.Count item(s)</span>
            </div>
            <div class="card-body p-0">
                @if (!ticket.Items.Any())
                {
                    <p class="text-muted small p-3 mb-0">No items yet.</p>
                }
                else
                {
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Description</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Unit</th>
                                <th class="text-end">Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ticket.Items)
                            {
                                <tr>
                                    <td>
                                        @if (item.ServiceTypeId.HasValue)
                                        {
                                            <span class="badge bg-info text-dark me-1">Service</span>@item.ServiceTypeName
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary me-1">Part</span>@item.PartName
                                        }
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">৳@item.UnitPrice.ToString("N2")</td>
                                    <td class="text-end fw-medium">৳@item.LineTotal.ToString("N2")</td>
                                    <td class="text-end">
                                        @if (ticket.Status != ServiceTicketStatus.ReadyForPickup &&
                                             ticket.Status != ServiceTicketStatus.Delivered)
                                        {
                                            <form asp-action="RemoveItem" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="itemId" value="@item.Id" />
                                                <input type="hidden" name="ticketId" value="@ticket.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1"
                                                        onclick="return confirm('Remove this item?')">&times;</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-semibold small">Subtotal</td>
                                <td class="text-end fw-bold">৳@ticket.Items.Sum(i => i.LineTotal).ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>

        @* Add items — only while Diagnosed / InProgress *@
        @if (ticket.Status == ServiceTicketStatus.Diagnosed || ticket.Status == ServiceTicketStatus.InProgress)
        {
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white fw-semibold small">Add Service</div>
                        <div class="card-body">
                            <form asp-action="AddItem" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ticket.Id" />
                                <input type="hidden" name="dto.PartId" value="" />
                                <div class="mb-2">
                                    <select name="dto.ServiceTypeId" id="stSelect" class="form-select form-select-sm"
                                            onchange="autoFillStPrice(this)">
                                        <option value="">— Select service —</option>
                                        @foreach (var st in Model.ServiceTypes)
                                        {
                                            <option value="@st.Id" data-price="@st.BasePrice">
                                                @st.Name (৳@st.BasePrice.ToString("N2"))
                                            </option>
                                        }
                                    </select>
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-5">
                                        <input type="number" name="dto.Quantity" value="1" min="1"
                                               class="form-control form-control-sm" placeholder="Qty" />
                                    </div>
                                    <div class="col-7">
                                        <input type="number" id="stPrice" name="dto.UnitPrice" step="0.01"
                                               class="form-control form-control-sm" placeholder="Price" />
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-sm btn-outline-primary w-100">Add Service</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white fw-semibold small">Add Part</div>
                        <div class="card-body">
                            <form asp-action="AddItem" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ticket.Id" />
                                <input type="hidden" name="dto.ServiceTypeId" value="" />
                                <div class="mb-2">
                                    <select name="dto.PartId" id="partSelect" class="form-select form-select-sm"
                                            onchange="autoFillPartPrice(this)">
                                        <option value="">— Select part —</option>
                                        @foreach (var p in Model.Parts)
                                        {
                                            if (p.StockQuantity == 0)
                                            {
                                                <option value="@p.Id" data-price="@p.UnitPrice" disabled>
                                                    @p.Name — Out of stock
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@p.Id" data-price="@p.UnitPrice">
                                                    @p.Name (Stock: @p.StockQuantity) — ৳@p.UnitPrice.ToString("N2")
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-5">
                                        <input type="number" name="dto.Quantity" value="1" min="1"
                                               class="form-control form-control-sm" placeholder="Qty" />
                                    </div>
                                    <div class="col-7">
                                        <input type="number" id="partPrice" name="dto.UnitPrice" step="0.01"
                                               class="form-control form-control-sm" placeholder="Price" />
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-sm btn-outline-secondary w-100">Add Part</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Notes / Communication *@
        @{
            var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        }
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Notes &amp; Communication</div>
            <div class="card-body p-3">
                <div class="d-flex flex-column gap-2 mb-3" style="max-height:340px;overflow-y:auto;" id="notesThread">
                    @if (!Model.Notes.Any())
                    {
                        <p class="text-muted small mb-0 text-center py-3">No notes yet. Use this to communicate with the customer.</p>
                    }
                    else
                    {
                        @foreach (var note in Model.Notes)
                        {
                            var isOwn = note.AuthorId == currentUserId;
                            <div class="d-flex @(isOwn ? "justify-content-end" : "justify-content-start")">
                                <div class="px-3 py-2 rounded-3 @(isOwn ? "text-white" : "bg-light border")"
                                     style="max-width:72%;@(isOwn ? "background:#0f4c35;" : "")">
                                    <div class="small fw-semibold mb-1 @(isOwn ? "text-white-50" : "text-muted")">
                                        @note.AuthorName
                                        <span class="badge @(note.AuthorRole == "Mechanic" ? "bg-success" : "bg-secondary") ms-1"
                                              style="font-size:.6rem;">@note.AuthorRole</span>
                                    </div>
                                    <div>@note.Message</div>
                                    <div class="mt-1 @(isOwn ? "text-white-50" : "text-muted")" style="font-size:.68rem;">
                                        @note.CreatedAt.ToString("MMM d, h:mm tt")
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
                <form asp-action="AddNote" asp-route-id="@Model.Ticket.Id" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="text" name="message" class="form-control form-control-sm"
                           placeholder="Message the customer…" maxlength="1000" required autocomplete="off" />
                    <button type="submit" class="btn btn-sm px-3 text-white" style="background:#0f4c35;">Send</button>
                </form>
            </div>
        </div>

    </div>

    @* ── Right column ── *@
    <div class="col-lg-4">

        @* Ticket info *@
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white fw-semibold small">Ticket Info</div>
            <ul class="list-group list-group-flush small">
                <li class="list-group-item d-flex justify-content-between py-2">
                    <span class="text-muted">Customer</span>
                    <span class="fw-medium">@(ticket.CustomerName ?? "—")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between py-2">
                    <span class="text-muted">Created</span>
                    <span>@ticket.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between py-2">
                    <span class="text-muted">Est. Completion</span>
                    <span class="@(ticket.IsOverdue ? "text-danger fw-medium" : "")">
                        @(ticket.EstimatedCompletionDate?.ToLocalTime().ToString("MMM d, yyyy") ?? "Not set")
                    </span>
                </li>
                <li class="list-group-item d-flex justify-content-between py-2">
                    <span class="text-muted">Invoice</span>
                    <span>@(ticket.HasInvoice ? "Generated" : "Not yet")</span>
                </li>
            </ul>
        </div>

        @* Diagnosis notes *@
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold small">Diagnosis Notes</div>
            <div class="card-body">
                <form asp-action="UpdateDiagnosis" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@ticket.Id" />
                    <div class="mb-2">
                        <textarea name="diagnosisNotes" rows="4" class="form-control form-control-sm"
                                  placeholder="Describe findings, issues diagnosed...">@ticket.DiagnosisNotes</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small mb-1">Est. Completion Date</label>
                        <input type="datetime-local" name="estimatedCompletion" class="form-control form-control-sm"
                               value="@(ticket.EstimatedCompletionDate?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm"))" />
                    </div>
                    <button type="submit" class="btn btn-sm w-100 text-white" style="background:#0f4c35;">
                        Save Notes
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function autoFillStPrice(sel) {
            document.getElementById('stPrice').value = sel.options[sel.selectedIndex]?.dataset.price || '';
        }
        function autoFillPartPrice(sel) {
            document.getElementById('partPrice').value = sel.options[sel.selectedIndex]?.dataset.price || '';
        }
        const thread = document.getElementById('notesThread');
        if (thread) thread.scrollTop = thread.scrollHeight;
    </script>
}
