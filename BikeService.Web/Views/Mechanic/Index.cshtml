@using BikeService.Domain.Enums
@model BikeService.Web.ViewModels.Mechanic.MechanicDashboardViewModel
@{
    Layout = "~/Views/Shared/_MechanicLayout.cshtml";
    ViewData["Title"] = "Dashboard";

    var fullName = User.Identity?.Name ?? "Mechanic";

    string StatusColor(ServiceTicketStatus s) => s switch
    {
        ServiceTicketStatus.Pending        => "secondary",
        ServiceTicketStatus.Diagnosed      => "info",
        ServiceTicketStatus.InProgress     => "primary",
        ServiceTicketStatus.QualityCheck   => "warning",
        ServiceTicketStatus.ReadyForPickup => "success",
        _                                  => "dark"
    };
}

@* ── Greeting ── *@
<div class="mb-4">
    <h4 class="fw-semibold mb-0">Good @(DateTime.Now.Hour < 12 ? "morning" : DateTime.Now.Hour < 17 ? "afternoon" : "evening"), @fullName.Split(' ')[0] 👋</h4>
    <p class="text-muted small mb-0">Here's what's on your plate today — @DateTime.Today.ToString("dddd, MMMM d")</p>
</div>

@* ── KPI Cards ── *@
<div class="row g-3 mb-4">

    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:44px;height:44px;background:#e8f5e9;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#0f4c35" viewBox="0 0 16 16">
                        <path d="M0 1.5A1.5 1.5 0 0 1 1.5 0h13A1.5 1.5 0 0 1 16 1.5v13a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13zm1.5-.5a.5.5 0 0 0-.5.5V5h14V1.5a.5.5 0 0 0-.5-.5h-13zM16 6H0v8.5a.5.5 0 0 0 .5.5h15a.5.5 0 0 0 .5-.5V6zM5 11a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm4 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                    </svg>
                </div>
                <div>
                    <div class="fw-bold fs-4 lh-1">@Model.TotalActive</div>
                    <div class="text-muted small">Active Tickets</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100 @(Model.OverdueCount > 0 ? "border-start border-danger border-3" : "")">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:44px;height:44px;background:@(Model.OverdueCount > 0 ? "#fdecea" : "#f8f9fa");">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                         fill="@(Model.OverdueCount > 0 ? "#c62828" : "#6c757d")" viewBox="0 0 16 16">
                        <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
                    </svg>
                </div>
                <div>
                    <div class="fw-bold fs-4 lh-1 @(Model.OverdueCount > 0 ? "text-danger" : "")">@Model.OverdueCount</div>
                    <div class="text-muted small">Overdue</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:44px;height:44px;background:#e3f2fd;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#1565c0" viewBox="0 0 16 16">
                        <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/>
                        <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.474l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115l.094-.319z"/>
                    </svg>
                </div>
                <div>
                    <div class="fw-bold fs-4 lh-1">@Model.InProgressCount</div>
                    <div class="text-muted small">In Progress</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100 @(Model.ReadyCount > 0 ? "border-start border-success border-3" : "")">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:44px;height:44px;background:#e8f5e9;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#2e7d32" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                    </svg>
                </div>
                <div>
                    <div class="fw-bold fs-4 lh-1 @(Model.ReadyCount > 0 ? "text-success" : "")">@Model.ReadyCount</div>
                    <div class="text-muted small">Ready for Pickup</div>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="row g-4">

    @* ── Active Tickets ── *@
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Active Tickets</span>
                <a asp-action="Tickets" class="btn btn-sm btn-outline-secondary">View All</a>
            </div>
            @if (!Model.ActiveTickets.Any())
            {
                <div class="card-body text-center py-5 text-muted">
                    <p class="mb-0 fw-medium">No active tickets assigned to you.</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var t in Model.ActiveTickets.Take(6))
                    {
                        <a asp-action="Detail" asp-route-id="@t.Id"
                           class="list-group-item list-group-item-action border-0 px-4 py-3">
                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="flex-grow-1 min-width-0">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="fw-medium text-truncate">@t.BikeSummary</span>
                                        @if (t.IsOverdue)
                                        {
                                            <span class="badge bg-danger flex-shrink-0">Overdue</span>
                                        }
                                    </div>
                                    <div class="small text-muted">
                                        @(t.CustomerName ?? "—")
                                        @if (t.EstimatedCompletionDate.HasValue)
                                        {
                                            <span class="ms-2">· Due @t.EstimatedCompletionDate.Value.ToLocalTime().ToString("MMM d")</span>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                    <span class="badge bg-@StatusColor(t.Status)">@t.StatusLabel</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                         fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                                    </svg>
                                </div>
                            </div>
                        </a>
                    }
                </div>
                @if (Model.TotalActive > 6)
                {
                    <div class="card-footer bg-transparent text-center">
                        <a asp-action="Tickets" class="text-decoration-none small">
                            +@(Model.TotalActive - 6) more tickets &rarr;
                        </a>
                    </div>
                }
            }
        </div>
    </div>

    @* ── Right column ── *@
    <div class="col-lg-4">

        @* Quick actions *@
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white fw-semibold">Quick Actions</div>
            <div class="list-group list-group-flush">
                <a asp-action="Tickets" class="list-group-item list-group-item-action border-0 px-4 py-3 d-flex align-items-center gap-3">
                    <span class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                          style="width:34px;height:34px;background:#e8f5e9;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#0f4c35" viewBox="0 0 16 16">
                            <path d="M0 1.5A1.5 1.5 0 0 1 1.5 0h13A1.5 1.5 0 0 1 16 1.5v13a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13zm1.5-.5a.5.5 0 0 0-.5.5V5h14V1.5a.5.5 0 0 0-.5-.5h-13zM16 6H0v8.5a.5.5 0 0 0 .5.5h15a.5.5 0 0 0 .5-.5V6zM5 11a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm4 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                        </svg>
                    </span>
                    <div>
                        <div class="fw-medium small">View All Tickets</div>
                        <div class="text-muted" style="font-size:.75rem;">@Model.TotalActive active work orders</div>
                    </div>
                </a>
                <a asp-action="Leave" class="list-group-item list-group-item-action border-0 px-4 py-3 d-flex align-items-center gap-3">
                    <span class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                          style="width:34px;height:34px;background:#e8f5e9;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#0f4c35" viewBox="0 0 16 16">
                            <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
                        </svg>
                    </span>
                    <div>
                        <div class="fw-medium small">My Leave</div>
                        <div class="text-muted" style="font-size:.75rem;">
                            @if (Model.PendingLeaveCount > 0)
                            {
                                <span class="text-warning fw-medium">@Model.PendingLeaveCount pending</span>
                            }
                            else
                            {
                                <span>No pending requests</span>
                            }
                        </div>
                    </div>
                </a>
                <a asp-action="LeaveCreate" class="list-group-item list-group-item-action border-0 px-4 py-3 d-flex align-items-center gap-3">
                    <span class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                          style="width:34px;height:34px;background:#e8f5e9;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#0f4c35" viewBox="0 0 16 16">
                            <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                            <path d="M14.5 3a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-13a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h13zm-13-1A2 2 0 0 0 0 4v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H2z"/>
                        </svg>
                    </span>
                    <div>
                        <div class="fw-medium small">Request Leave</div>
                        <div class="text-muted" style="font-size:.75rem;">Submit a new time-off request</div>
                    </div>
                </a>
            </div>
        </div>

        @* Recent leave *@
        @if (Model.RecentLeave.Any())
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Recent Leave</span>
                    <a asp-action="Leave" class="small text-decoration-none">View all</a>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var l in Model.RecentLeave)
                    {
                        var badge = l.Status switch
                        {
                            LeaveRequestStatus.Pending  => "bg-warning text-dark",
                            LeaveRequestStatus.Approved => "bg-success",
                            LeaveRequestStatus.Rejected => "bg-danger",
                            _                           => "bg-secondary",
                        };
                        <li class="list-group-item border-0 px-4 py-2 d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small fw-medium">@l.Type — @l.TotalDays day@(l.TotalDays != 1 ? "s" : "")</div>
                                <div class="text-muted" style="font-size:.72rem;">
                                    @l.FromDate.ToString("MMM d") – @l.ToDate.ToString("MMM d, yyyy")
                                </div>
                            </div>
                            <span class="badge @badge">@l.Status</span>
                        </li>
                    }
                </ul>
            </div>
        }

    </div>
</div>
