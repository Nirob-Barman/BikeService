@model List<BikeService.Application.DTOs.LeaveRequest.LeaveRequestDto>
@using BikeService.Domain.Enums
@{
    Layout = "~/Views/Shared/_MechanicLayout.cshtml";
    ViewData["Title"] = "My Leave Requests";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-semibold mb-0">My Leave Requests</h4>
        <p class="text-muted small mb-0">Track and manage your time-off requests</p>
    </div>
    <a asp-action="LeaveCreate" class="btn btn-sm text-white px-3" style="background:#0f4c35;">
        + New Request
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                 class="mb-3 opacity-25" viewBox="0 0 16 16">
                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
            </svg>
            <p class="mb-1 fw-medium">No leave requests yet.</p>
            <a asp-action="LeaveCreate" class="btn btn-sm btn-outline-secondary mt-1">Submit your first request</a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var r in Model)
        {
            var (badgeClass, bgCard) = r.Status switch
            {
                LeaveRequestStatus.Pending  => ("bg-warning text-dark", ""),
                LeaveRequestStatus.Approved => ("bg-success", "border-start border-success border-3"),
                LeaveRequestStatus.Rejected => ("bg-danger",  "border-start border-danger border-3"),
                _                           => ("bg-secondary", "opacity-75"),
            };
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100 @bgCard">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="fw-semibold">@r.Type Leave</span>
                            <span class="badge @badgeClass">@r.Status</span>
                        </div>

                        <div class="d-flex align-items-center gap-2 text-muted small mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
                            </svg>
                            @r.FromDate.ToString("MMM d") – @r.ToDate.ToString("MMM d, yyyy")
                            <span class="badge bg-light text-dark border">@r.TotalDays day@(r.TotalDays != 1 ? "s" : "")</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(r.Reason))
                        {
                            <p class="small text-muted mb-2" style="line-height:1.4;">@r.Reason</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(r.AdminNotes))
                        {
                            <div class="small p-2 rounded @(r.Status == LeaveRequestStatus.Approved ? "bg-success bg-opacity-10" : "bg-danger bg-opacity-10") mb-2">
                                <span class="fw-medium">Admin:</span> @r.AdminNotes
                            </div>
                        }

                        <p class="text-muted mb-0" style="font-size:.7rem;">
                            Submitted @r.CreatedAt.ToString("MMM d, yyyy")
                        </p>
                    </div>

                    @if (r.Status == LeaveRequestStatus.Pending)
                    {
                        <div class="card-footer bg-transparent border-0 pt-0">
                            <form asp-action="LeaveCancel" asp-route-id="@r.Id" method="post"
                                  onsubmit="return confirm('Cancel this leave request?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Cancel Request</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
