@using BikeService.Application.DTOs.PaymentGateway
@model List<PaymentGatewayDto>
@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Payment Gateways";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Payment Gateways</h4>
    <a href="@Url.Action("Create")" class="btn btn-primary btn-sm">+ Add Gateway</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Mode</th>
                        <th>Status</th>
                        <th>Transactions</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No payment gateways configured.</td>
                        </tr>
                    }
                    @foreach (var gw in Model)
                    {
                        <tr>
                            <td class="fw-medium">@gw.Name</td>
                            <td><code class="text-primary">@gw.Slug</code></td>
                            <td>
                                @if (gw.IsSandbox)
                                {
                                    <span class="badge bg-warning text-dark">Sandbox</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Live</span>
                                }
                            </td>
                            <td>
                                @if (gw.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-muted">@gw.TransactionCount</td>
                            <td class="text-muted small">@gw.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <a href="@Url.Action("Edit", new { id = gw.Id })" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form method="post" asp-action="Toggle" asp-route-id="@gw.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(gw.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-1">
                                        @(gw.IsActive ? "Disable" : "Enable")
                                    </button>
                                </form>
                                <button type="button" class="btn btn-sm btn-outline-danger ms-1"
                                        onclick="confirmDelete('@Url.Action("Delete", new { id = gw.Id })')">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
function confirmDelete(url) {
    Swal.fire({ title: 'Delete Gateway?', icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Delete' })
    .then(r => {
        if (r.isConfirmed) {
            var f = document.createElement('form'); f.method = 'POST'; f.action = url;
            var t = document.createElement('input'); t.type = 'hidden'; t.name = '__RequestVerificationToken';
            t.value = document.querySelector('input[name=__RequestVerificationToken]')?.value || '';
            f.appendChild(t); document.body.appendChild(f); f.submit();
        }
    });
}
</script>
}
