@model BikeService.Web.ViewModels.PromoCode.PromoCodeFormViewModel
@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Promo Code";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Edit Promo Code</h4>
    <a asp-controller="PromoCode" asp-action="Index" class="btn btn-outline-secondary">
        &larr; Back to List
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 580px;">
    <div class="card-body p-4">
        <form asp-controller="PromoCode" asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label asp-for="Code" class="form-label fw-medium"></label>
                <input asp-for="Code" class="form-control font-monospace text-uppercase" autocomplete="off" />
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label asp-for="DiscountPercent" class="form-label fw-medium"></label>
                    <div class="input-group">
                        <input asp-for="DiscountPercent" class="form-control" type="number" step="0.01" min="0.01" max="100" />
                        <span class="input-group-text">%</span>
                    </div>
                    <span asp-validation-for="DiscountPercent" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="MaxUsages" class="form-label fw-medium"></label>
                    <input asp-for="MaxUsages" class="form-control" type="number" min="1" />
                    <span asp-validation-for="MaxUsages" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="ExpiresAt" class="form-label fw-medium"></label>
                <input asp-for="ExpiresAt" class="form-control" type="date" />
                <div class="form-text">Leave blank for no expiry.</div>
                <span asp-validation-for="ExpiresAt" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active (available to customers)</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                <a asp-controller="PromoCode" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
