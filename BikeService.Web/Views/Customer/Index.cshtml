@using BikeService.Application.DTOs.Customer
@model List<CustomerDto>
@{
    ViewData["Title"] = "Customers";
}

<div class="adm-page-head">
    <div>
        <h1 class="adm-page-head-title">Customers</h1>
        <p class="adm-page-head-sub" id="countLabel">Total: @Model.Count</p>
    </div>
</div>

<div class="adm-card" style="margin-bottom:1rem;">
    <div class="adm-card-body" style="padding:.75rem 1.25rem;">
        <div style="display:flex;align-items:center;gap:.5rem;max-width:380px;">
            <div style="position:relative;flex:1;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                     style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
                <input type="text" id="customerSearch" class="adm-input" style="padding-left:2.25rem;width:100%;"
                       placeholder="Search by name or email…" autocomplete="off" />
            </div>
            <button class="adm-btn adm-btn-secondary adm-btn-sm" type="button" onclick="clearSearch()">Clear</button>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="adm-card">
        <div class="adm-card-body">
            <div class="adm-empty">
                <div class="adm-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                    </svg>
                </div>
                <p class="adm-empty-title">No customers yet</p>
                <p class="adm-empty-sub">Customers will appear here after they register an account.</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="adm-card">
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var customer in Model)
                    {
                        <tr data-search="@((customer.FullName + " " + customer.Email).ToLower())">
                            <td>
                                <div style="display:flex;align-items:center;gap:.625rem;">
                                    <div style="width:34px;height:34px;border-radius:50%;background:var(--p);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:600;flex-shrink:0;">
                                        @(customer.FullName?.Length > 0 ? customer.FullName[0].ToString().ToUpper() : "?")
                                    </div>
                                    <span style="font-weight:500;">@customer.FullName</span>
                                </div>
                            </td>
                            <td style="color:var(--muted);">@customer.Email</td>
                            <td>
                                @if (customer.IsBanned)
                                {
                                    <span class="adm-badge danger">Banned</span>
                                }
                                else
                                {
                                    <span class="adm-badge success">Active</span>
                                }
                            </td>
                            <td style="color:var(--muted);font-size:.8125rem;">@customer.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td style="text-align:right;">
                                @if (customer.IsBanned)
                                {
                                    <form method="post" asp-action="Unban" asp-route-id="@customer.Id" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="adm-btn adm-btn-primary adm-btn-sm">Unban</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-action="Ban" asp-route-id="@customer.Id" class="ban-form" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="adm-btn adm-btn-danger adm-btn-sm btn-ban"
                                                data-name="@customer.FullName">Ban</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
    document.querySelectorAll('.btn-ban').forEach(btn => {
        btn.addEventListener('click', function () {
            const name = this.dataset.name;
            const form = this.closest('.ban-form');
            Swal.fire({
                title: 'Ban customer?',
                html: `<strong>${name}</strong> will be locked out and unable to log in.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#DC2626',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, ban'
            }).then(result => { if (result.isConfirmed) form.submit(); });
        });
    });

    const searchInput = document.getElementById('customerSearch');
    const countLabel  = document.getElementById('countLabel');
    const totalCount  = @Model.Count;

    function filterTable() {
        const q    = searchInput.value.trim().toLowerCase();
        const rows = document.querySelectorAll('tbody tr[data-search]');
        let visible = 0;
        rows.forEach(row => {
            const match = !q || row.dataset.search.includes(q);
            row.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        countLabel.textContent = q ? `Showing ${visible} of ${totalCount}` : `Total: ${totalCount}`;
    }

    function clearSearch() {
        searchInput.value = '';
        filterTable();
        searchInput.focus();
    }

    searchInput.addEventListener('input', filterTable);
</script>
}
