@model List<BikeService.Application.DTOs.CustomerBike.CustomerBikeDto>
@{
    ViewData["Title"] = "My Bikes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <h4 class="mb-0 fw-semibold">My Bikes</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Register Bike</a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem;" class="mb-3">🚲</div>
        <p class="mb-3">You haven't registered any bikes yet.</p>
        <a asp-action="Create" class="btn btn-primary">Register Your First Bike</a>
    </div>
}
else
{
    <div class="row gy-4">
        @foreach (var bike in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    @if (!string.IsNullOrWhiteSpace(bike.ImageUrl))
                    {
                        <img src="@bike.ImageUrl" class="card-img-top"
                             style="height:180px;object-fit:cover;" alt="@bike.Make @bike.Model" />
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                             style="height:180px;">
                            <span style="font-size:3.5rem;">🚲</span>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="fw-semibold mb-1">@bike.Make @bike.Model</h5>
                        <p class="text-muted small mb-2">
                            @bike.Year
                            @if (!string.IsNullOrWhiteSpace(bike.RegistrationNo))
                            {
                                <span class="ms-2">&bull; @bike.RegistrationNo</span>
                            }
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@bike.Id"
                           class="btn btn-outline-secondary btn-sm">Edit</a>
                        <a asp-controller="Appointment" asp-action="Create"
                           class="btn btn-outline-primary btn-sm">Book Service</a>
                        <form asp-action="Delete" asp-route-id="@bike.Id" method="post" class="ms-auto"
                              onsubmit="return confirm('Delete this bike?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
