@using BikeService.Application.DTOs.ServiceTicket
@using BikeService.Application.DTOs.Mechanic
@using BikeService.Domain.Enums
@model List<ServiceTicketDto>
@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Service Tickets";

    string GetStatusColor(ServiceTicketStatus s) => s switch
    {
        ServiceTicketStatus.Pending => "secondary",
        ServiceTicketStatus.Diagnosed => "info",
        ServiceTicketStatus.InProgress => "primary",
        ServiceTicketStatus.QualityCheck => "warning",
        ServiceTicketStatus.ReadyForPickup => "success",
        ServiceTicketStatus.Delivered => "dark",
        ServiceTicketStatus.Cancelled => "danger",
        _ => "secondary"
    };

    var mechanics = ViewBag.Mechanics as List<MechanicDto> ?? new List<MechanicDto>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Service Tickets</h4>
    <div class="d-flex align-items-center gap-3">
        <span class="text-muted small" id="countLabel">@Model.Count result(s)</span>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> New Walk-In
        </a>
    </div>
</div>

<!-- Filter -->
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body py-2 px-3">
        <div class="input-group input-group-sm" style="max-width:360px;">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="ticketSearch" class="form-control border-start-0"
                   placeholder="Search by bike, customer, mechanic…" autocomplete="off" />
            <button class="btn btn-outline-secondary" type="button" onclick="clearSearch()">Clear</button>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label small fw-medium">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (ServiceTicketStatus s in Enum.GetValues(typeof(ServiceTicketStatus)))
                    {
                        <option value="@s" selected="@(ViewBag.StatusFilter?.ToString() == s.ToString() ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-medium">Mechanic</label>
                <select name="mechanicId" class="form-select form-select-sm">
                    <option value="">All Mechanics</option>
                    @foreach (var m in mechanics)
                    {
                        <option value="@m.Id" selected="@(ViewBag.MechanicIdFilter?.ToString() == m.Id.ToString() ? "selected" : null)">@m.FullName</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-medium">From</label>
                <input type="date" name="dateFrom" class="form-control form-control-sm" value="@ViewBag.DateFrom" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-medium">To</label>
                <input type="date" name="dateTo" class="form-control form-control-sm" value="@ViewBag.DateTo" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">Filter</button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#ID</th>
                        <th>Bike</th>
                        <th>Customer</th>
                        <th>Mechanic</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No tickets found.</td>
                        </tr>
                    }
                    @foreach (var ticket in Model)
                    {
                        <tr data-search="@((ticket.BikeSummary + " " + ticket.CustomerName + " " + (ticket.MechanicName ?? "")).ToLower())">
                            <td class="text-muted small">#@ticket.Id</td>
                            <td class="fw-medium">@ticket.BikeSummary</td>
                            <td class="text-muted">@ticket.CustomerName</td>
                            <td class="text-muted">@(ticket.MechanicName ?? "—")</td>
                            <td>
                                <span class="badge bg-@GetStatusColor(ticket.Status)">@ticket.StatusLabel</span>
                                @if (ticket.IsOverdue)
                                {
                                    <span class="badge bg-danger ms-1">Overdue</span>
                                }
                            </td>
                            <td class="text-muted small">@ticket.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <a href="@Url.Action("Detail", new { id = ticket.Id })" class="btn btn-sm btn-outline-primary">Detail</a>
                                @if (ticket.Status != ServiceTicketStatus.Cancelled && ticket.Status != ServiceTicketStatus.Delivered)
                                {
                                    <form method="post" asp-action="Cancel" asp-route-id="@ticket.Id" class="d-inline"
                                          onsubmit="return confirm('Cancel ticket #@ticket.Id?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Cancel</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const searchInput = document.getElementById('ticketSearch');
    const countLabel  = document.getElementById('countLabel');
    const totalCount  = @Model.Count;

    function filterTable() {
        const q    = searchInput.value.trim().toLowerCase();
        const rows = document.querySelectorAll('tbody tr[data-search]');
        let visible = 0;
        rows.forEach(row => {
            const match = !q || row.dataset.search.includes(q);
            row.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        countLabel.textContent = q
            ? `Showing ${visible} of ${totalCount} result(s)`
            : `${totalCount} result(s)`;
    }

    function clearSearch() {
        searchInput.value = '';
        filterTable();
        searchInput.focus();
    }

    searchInput.addEventListener('input', filterTable);
</script>
}
