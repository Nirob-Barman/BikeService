@using BikeService.Application.DTOs.ServiceTicket
@using BikeService.Application.DTOs.Mechanic
@using BikeService.Domain.Enums
@model List<ServiceTicketDto>
@{
    ViewData["Title"] = "Service Tickets";

    string GetStatusBadge(ServiceTicketStatus s) => s switch
    {
        ServiceTicketStatus.Pending        => "neutral",
        ServiceTicketStatus.Diagnosed      => "info",
        ServiceTicketStatus.InProgress     => "primary",
        ServiceTicketStatus.QualityCheck   => "warning",
        ServiceTicketStatus.ReadyForPickup => "success",
        ServiceTicketStatus.Delivered      => "neutral",
        ServiceTicketStatus.Cancelled      => "danger",
        _ => "neutral"
    };

    var mechanics = ViewBag.Mechanics as List<MechanicDto> ?? new List<MechanicDto>();
}

<div class="adm-page-head">
    <div>
        <h1 class="adm-page-head-title">Service Tickets</h1>
        <p class="adm-page-head-sub" id="countLabel">@Model.Count result(s)</p>
    </div>
    <a asp-action="Create" class="adm-btn adm-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="margin-right:.375rem;vertical-align:-.1em;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        New Walk-In
    </a>
</div>

<div class="adm-card" style="margin-bottom:1rem;">
    <div class="adm-card-body" style="padding:.75rem 1.25rem;">
        <div style="display:flex;align-items:center;gap:.5rem;max-width:400px;">
            <div style="position:relative;flex:1;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                     style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
                <input type="text" id="ticketSearch" class="adm-input" style="padding-left:2.25rem;width:100%;"
                       placeholder="Search by bike, customer, mechanic…" autocomplete="off" />
            </div>
            <button class="adm-btn adm-btn-secondary adm-btn-sm" type="button" onclick="clearSearch()">Clear</button>
        </div>
    </div>
</div>

<div class="adm-card" style="margin-bottom:1rem;">
    <div class="adm-card-body" style="padding:.875rem 1.25rem;">
        <form method="get" style="display:flex;gap:.75rem;flex-wrap:wrap;align-items:flex-end;">
            <div>
                <label class="adm-label">Status</label>
                <select name="status" class="adm-input adm-select" style="width:150px;">
                    <option value="">All</option>
                    @foreach (ServiceTicketStatus s in Enum.GetValues(typeof(ServiceTicketStatus)))
                    {
                        <option value="@s" selected="@(ViewBag.StatusFilter?.ToString() == s.ToString() ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div>
                <label class="adm-label">Mechanic</label>
                <select name="mechanicId" class="adm-input adm-select" style="width:170px;">
                    <option value="">All Mechanics</option>
                    @foreach (var m in mechanics)
                    {
                        <option value="@m.Id" selected="@(ViewBag.MechanicIdFilter?.ToString() == m.Id.ToString() ? "selected" : null)">@m.FullName</option>
                    }
                </select>
            </div>
            <div>
                <label class="adm-label">From</label>
                <input type="date" name="dateFrom" class="adm-input" style="width:150px;" value="@ViewBag.DateFrom" />
            </div>
            <div>
                <label class="adm-label">To</label>
                <input type="date" name="dateTo" class="adm-input" style="width:150px;" value="@ViewBag.DateTo" />
            </div>
            <div style="display:flex;gap:.5rem;align-items:flex-end;">
                <button type="submit" class="adm-btn adm-btn-primary adm-btn-sm">Filter</button>
                <a href="@Url.Action("Index")" class="adm-btn adm-btn-secondary adm-btn-sm">Reset</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="adm-card">
        <div class="adm-card-body">
            <div class="adm-empty">
                <div class="adm-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
                    </svg>
                </div>
                <p class="adm-empty-title">No tickets found</p>
                <p class="adm-empty-sub">Try adjusting your filters. New tickets appear when walk-in customers are checked in or appointments are confirmed.</p>
                <a asp-action="Create" class="adm-btn adm-btn-primary" style="margin-top:1rem;">Create Walk-In Ticket</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="adm-card">
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Bike</th>
                        <th>Customer</th>
                        <th>Mechanic</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model)
                    {
                        <tr data-search="@((ticket.BikeSummary + " " + ticket.CustomerName + " " + (ticket.MechanicName ?? "")).ToLower())">
                            <td style="color:var(--muted);font-size:.8125rem;">#@ticket.Id</td>
                            <td style="font-weight:500;">@ticket.BikeSummary</td>
                            <td style="color:var(--muted);">@ticket.CustomerName</td>
                            <td style="color:var(--muted);">@(ticket.MechanicName ?? "—")</td>
                            <td>
                                <span class="adm-badge @GetStatusBadge(ticket.Status)">@ticket.StatusLabel</span>
                                @if (ticket.IsOverdue)
                                {
                                    <span class="adm-badge danger" style="margin-left:.25rem;">Overdue</span>
                                }
                            </td>
                            <td style="color:var(--muted);font-size:.8125rem;white-space:nowrap;">@ticket.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td style="text-align:right;">
                                <div style="display:inline-flex;gap:.375rem;">
                                    <a href="@Url.Action("Detail", new { id = ticket.Id })" class="adm-btn adm-btn-secondary adm-btn-sm">Detail</a>
                                    @if (ticket.Status != ServiceTicketStatus.Cancelled && ticket.Status != ServiceTicketStatus.Delivered)
                                    {
                                        <form method="post" asp-action="Cancel" asp-route-id="@ticket.Id" style="display:inline;"
                                              onsubmit="return confirm('Cancel ticket #@ticket.Id?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="adm-btn adm-btn-danger adm-btn-sm">Cancel</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
    const searchInput = document.getElementById('ticketSearch');
    const countLabel  = document.getElementById('countLabel');
    const totalCount  = @Model.Count;

    function filterTable() {
        const q    = searchInput.value.trim().toLowerCase();
        const rows = document.querySelectorAll('tbody tr[data-search]');
        let visible = 0;
        rows.forEach(row => {
            const match = !q || row.dataset.search.includes(q);
            row.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        countLabel.textContent = q
            ? `Showing ${visible} of ${totalCount} result(s)`
            : `${totalCount} result(s)`;
    }

    function clearSearch() {
        searchInput.value = '';
        filterTable();
        searchInput.focus();
    }

    searchInput.addEventListener('input', filterTable);
</script>
}
