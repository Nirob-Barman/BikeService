@* ════════════════════════════════════════════
   SERVICES
════════════════════════════════════════════ *@
<section class="services-section" id="services">
    <div class="lp-container">
        <div class="section-header" data-anim>
            <span class="section-label">Services</span>
            <h2 class="section-title">Quality care for every bike</h2>
            <p class="section-sub">From routine tune-ups to complex overhauls — our certified mechanics handle it all.</p>
        </div>

        @if (Model.ServiceTypes.Any())
        {
            <div class="services-grid">
                @{
                    var icons = new[] { "🔧", "🔩", "⚙️", "🛞", "⛓️", "🔋", "🛠️", "🔦" };
                    var si = 0;
                }
                @foreach (var svc in Model.ServiceTypes)
                {
                    <div class="service-card" data-anim>
                        <div class="service-icon">@icons[si % icons.Length]</div>
                        <div class="service-name">@svc.Name</div>
                        @if (!string.IsNullOrWhiteSpace(svc.Description))
                        {
                            <p class="service-desc">@svc.Description</p>
                        }
                        else
                        {
                            <p class="service-desc">Professional service by our certified mechanics with genuine parts.</p>
                        }
                        <div class="service-footer">
                            <div>
                                <div class="service-price">৳@svc.BasePrice.ToString("N0")</div>
                                <div class="service-est">~@svc.EstimatedHours hrs</div>
                            </div>
                            <a asp-controller="Appointment" asp-action="Create" class="btn-book">
                                Book Now
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M5 12h14M12 5l7 7-7 7"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                    si++;
                }
            </div>
        }
        else
        {
            <p style="text-align:center;color:var(--muted);padding:3rem 0;">No services available at the moment.</p>
        }
    </div>
</section>

