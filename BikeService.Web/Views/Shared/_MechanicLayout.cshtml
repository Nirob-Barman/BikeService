@using System.Security.Claims
@using BikeService.Application.Interfaces
@inject INotificationService NotificationService
@{
    if (!User.IsInRole("Mechanic"))
    {
        Context.Response.Redirect("/Account/Login");
        return;
    }

    var fullName  = User.FindFirstValue(ClaimTypes.Name) ?? "Mechanic";
    var initial   = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "M";
    var userId    = User.FindFirstValue(ClaimTypes.NameIdentifier)!;
    var unread    = await NotificationService.GetUnreadCountAsync(userId);
    var ctrl      = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action    = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";

    bool IsActive(string c, string a) => ctrl == c && action == a;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle — Mechanic | BikeService</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ── Design Tokens ── */
        :root {
            --sb-w:       220px;
            --sb-mini:    60px;
            --tb-h:       56px;
            --bg:         #F8FAFC;
            --surface:    #FFFFFF;
            --border:     #E2E8F0;
            /* Green accent (content area, topbar elements) */
            --mp:         #10B981;
            --mp-dark:    #059669;
            --mp-light:   #ECFDF5;
            --mp-ring:    rgba(16,185,129,.12);
            /* Sidebar dark green */
            --msb:        #0A3D24;
            --msb-hover:  rgba(255,255,255,.07);
            --msb-active: rgba(255,255,255,.13);
            --msb-text:   rgba(255,255,255,.68);
            --msb-act-t:  #ffffff;
            --msb-label:  rgba(255,255,255,.28);
            --msb-bdr:    rgba(255,255,255,.08);
            --msb-acc:    #34D399;
            /* General */
            --text:       #0F172A;
            --text-2:     #334155;
            --muted:      #64748B;
            --label:      #94A3B8;
            --hover:      #F1F5F9;
            --radius:     8px;
            --radius-lg:  12px;
            --shadow-sm:  0 1px 2px rgba(0,0,0,.05);
            --shadow:     0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
            --shadow-md:  0 4px 6px -1px rgba(0,0,0,.07), 0 2px 4px -1px rgba(0,0,0,.04);
            --t:          200ms ease;
            --font:       'Inter', system-ui, -apple-system, sans-serif;
            --success:    #16A34A; --success-bg: #DCFCE7;
            --warning:    #D97706; --warning-bg: #FEF3C7;
            --danger:     #DC2626; --danger-bg:  #FEE2E2;
            --info:       #2563EB; --info-bg:    #DBEAFE;
        }

        /* ── Reset ── */
        *, *::before, *::after { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            font-size: 14px;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        /* ════════════════════════════════
           SIDEBAR
        ════════════════════════════════ */
        .mch-sidebar {
            position: fixed;
            left: 0; top: 0;
            width: var(--sb-w);
            height: 100vh;
            background: var(--msb);
            display: flex;
            flex-direction: column;
            z-index: 200;
            transition: width var(--t), transform var(--t);
            overflow: hidden;
        }

        /* Logo */
        .mch-logo {
            height: var(--tb-h);
            display: flex;
            align-items: center;
            padding: 0 1rem;
            border-bottom: 1px solid var(--msb-bdr);
            gap: .625rem;
            flex-shrink: 0;
            text-decoration: none;
        }
        .mch-logo-icon {
            width: 28px; height: 28px;
            background: rgba(52,211,153,.18);
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .8rem;
            flex-shrink: 0;
        }
        .mch-logo-text {
            font-size: .9375rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: -.025em;
            white-space: nowrap;
            transition: opacity var(--t), width var(--t);
        }
        .mch-logo-badge {
            font-size: .625rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: var(--msb-acc);
            background: rgba(52,211,153,.15);
            padding: .15rem .45rem;
            border-radius: 4px;
            white-space: nowrap;
            transition: opacity var(--t);
        }

        /* Nav scroll area */
        .mch-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: .625rem 0;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,.08) transparent;
        }
        .mch-nav::-webkit-scrollbar { width: 3px; }
        .mch-nav::-webkit-scrollbar-track { background: transparent; }
        .mch-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 4px; }

        /* Section */
        .mch-nav-section { padding: 0 .5rem; }
        .mch-nav-section + .mch-nav-section { margin-top: .125rem; }

        .mch-nav-label {
            display: block;
            font-size: .6875rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--msb-label);
            padding: .625rem .5rem .25rem;
            white-space: nowrap;
            overflow: hidden;
            transition: opacity var(--t), height var(--t);
        }

        /* Nav item */
        .mch-nav-item {
            display: flex;
            align-items: center;
            gap: .625rem;
            padding: .45rem .625rem;
            margin: 1px 0;
            border-radius: var(--radius);
            text-decoration: none;
            font-size: .8125rem;
            font-weight: 500;
            color: var(--msb-text);
            transition: background var(--t), color var(--t);
            white-space: nowrap;
            position: relative;
        }
        .mch-nav-item:hover {
            background: var(--msb-hover);
            color: #fff;
            text-decoration: none;
        }
        .mch-nav-item.active {
            background: var(--msb-active);
            color: var(--msb-act-t);
            font-weight: 600;
        }
        .mch-nav-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            width: 16px; height: 16px;
        }
        .mch-nav-item.active .mch-nav-icon { color: var(--msb-acc); }
        .mch-nav-text { transition: opacity var(--t); }

        /* Sidebar footer */
        .mch-sidebar-foot {
            border-top: 1px solid var(--msb-bdr);
            padding: .625rem .5rem;
            flex-shrink: 0;
        }
        .mch-collapse-btn {
            display: flex;
            align-items: center;
            gap: .625rem;
            width: 100%;
            padding: .45rem .625rem;
            border-radius: var(--radius);
            background: none;
            border: none;
            font-family: var(--font);
            font-size: .8125rem;
            font-weight: 500;
            color: var(--msb-text);
            cursor: pointer;
            transition: background var(--t), color var(--t);
            white-space: nowrap;
        }
        .mch-collapse-btn:hover { background: var(--msb-hover); color: #fff; }
        .mch-collapse-icon {
            display: flex;
            align-items: center;
            flex-shrink: 0;
            transition: transform var(--t);
        }
        .mch-collapse-text { transition: opacity var(--t); }

        /* ── Mini (collapsed) state ── */
        .mch-sidebar.mini { width: var(--sb-mini); }

        .mch-sidebar.mini .mch-logo-text,
        .mch-sidebar.mini .mch-logo-badge { opacity: 0; width: 0; overflow: hidden; }

        .mch-sidebar.mini .mch-logo { justify-content: center; padding: 0; }

        .mch-sidebar.mini .mch-nav-label { opacity: 0; height: 0; padding-top: 0; padding-bottom: 0; }

        .mch-sidebar.mini .mch-nav-section { padding: 0 .375rem; }

        .mch-sidebar.mini .mch-nav-item {
            justify-content: center;
            padding: .5rem;
            gap: 0;
        }
        .mch-sidebar.mini .mch-nav-text { opacity: 0; width: 0; overflow: hidden; }

        .mch-sidebar.mini .mch-collapse-btn { justify-content: center; padding: .5rem; }
        .mch-sidebar.mini .mch-collapse-text { opacity: 0; width: 0; overflow: hidden; }
        .mch-sidebar.mini .mch-collapse-icon { transform: rotate(180deg); }

        /* Mini tooltip */
        .mch-sidebar.mini .mch-nav-item[data-label]:hover::after {
            content: attr(data-label);
            position: absolute;
            left: calc(100% + .625rem);
            top: 50%;
            transform: translateY(-50%);
            background: #1E293B;
            color: #fff;
            font-size: .75rem;
            font-weight: 500;
            padding: .3rem .625rem;
            border-radius: 6px;
            white-space: nowrap;
            z-index: 400;
            box-shadow: var(--shadow-md);
            pointer-events: none;
        }

        /* ════════════════════════════════
           MAIN WRAPPER
        ════════════════════════════════ */
        .mch-wrap {
            margin-left: var(--sb-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left var(--t);
        }
        .mch-wrap.mini { margin-left: var(--sb-mini); }

        /* ════════════════════════════════
           TOPBAR
        ════════════════════════════════ */
        .mch-topbar {
            position: sticky;
            top: 0;
            height: var(--tb-h);
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            gap: .875rem;
            z-index: 100;
            flex-shrink: 0;
        }
        .mch-topbar-left {
            display: flex;
            align-items: center;
            gap: .625rem;
            flex: 1;
            min-width: 0;
        }
        .mch-toggle-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 32px; height: 32px;
            border-radius: var(--radius);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--muted);
            transition: background var(--t), color var(--t);
            flex-shrink: 0;
        }
        .mch-toggle-btn:hover { background: var(--hover); color: var(--text); }

        .mch-page-title {
            font-size: .9375rem;
            font-weight: 600;
            color: var(--text);
            letter-spacing: -.015em;
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Role pill in topbar */
        .mch-role-pill {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            font-size: .6875rem;
            font-weight: 600;
            padding: .2rem .55rem;
            border-radius: 20px;
            background: var(--mp-light);
            color: var(--mp-dark);
            white-space: nowrap;
            flex-shrink: 0;
        }

        .mch-topbar-right {
            display: flex;
            align-items: center;
            gap: .25rem;
            flex-shrink: 0;
        }
        .mch-icon-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 32px; height: 32px;
            border-radius: var(--radius);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--muted);
            transition: background var(--t), color var(--t);
            position: relative;
            text-decoration: none;
        }
        .mch-icon-btn:hover { background: var(--hover); color: var(--text); }
        .mch-topbar-divider { width: 1px; height: 18px; background: var(--border); margin: 0 .125rem; }

        /* Notification badge */
        .mch-bell-count {
            position: absolute;
            top: 3px; right: 2px;
            min-width: 16px; height: 16px;
            background: #EF4444;
            color: #fff;
            font-size: .6rem;
            font-weight: 700;
            border-radius: 8px;
            padding: 0 .2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1.5px solid var(--surface);
            line-height: 1;
        }

        /* User dropdown */
        .mch-user-drop { position: relative; }
        .mch-user-btn {
            display: flex;
            align-items: center;
            gap: .45rem;
            height: 32px;
            padding: 0 .375rem;
            border-radius: var(--radius);
            background: none;
            border: none;
            cursor: pointer;
            transition: background var(--t);
        }
        .mch-user-btn:hover { background: var(--hover); }
        .mch-avatar {
            width: 26px; height: 26px;
            border-radius: 50%;
            background: var(--mp-light);
            color: var(--mp-dark);
            font-size: .725rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            overflow: hidden;
        }
        .mch-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .mch-user-name {
            font-size: .8125rem;
            font-weight: 500;
            color: var(--text);
            white-space: nowrap;
        }
        .mch-user-caret { color: var(--label); display: flex; transition: transform var(--t); }
        .mch-user-drop.open .mch-user-caret { transform: rotate(180deg); }

        .mch-drop-menu {
            position: absolute;
            right: 0;
            top: calc(100% + .375rem);
            width: 200px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md), 0 8px 24px rgba(0,0,0,.06);
            z-index: 500;
            padding: .375rem;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-6px);
            transition: opacity var(--t), visibility var(--t), transform var(--t);
        }
        .mch-user-drop.open .mch-drop-menu { opacity: 1; visibility: visible; transform: translateY(0); }
        .mch-drop-head {
            padding: .625rem .75rem .5rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: .25rem;
        }
        .mch-drop-head-name { font-size: .8125rem; font-weight: 600; color: var(--text); }
        .mch-drop-head-role { font-size: .7rem; color: var(--muted); margin-top: .1rem; }
        .mch-drop-item {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: .45rem .75rem;
            border-radius: 6px;
            text-decoration: none;
            font-size: .8125rem;
            font-weight: 500;
            color: var(--text-2);
            transition: background var(--t), color var(--t);
            width: 100%;
            background: none;
            border: none;
            cursor: pointer;
            font-family: var(--font);
            text-align: left;
        }
        .mch-drop-item:hover { background: var(--hover); color: var(--text); }
        .mch-drop-item.danger { color: #DC2626; }
        .mch-drop-item.danger:hover { background: #FEE2E2; }
        .mch-drop-divider { height: 1px; background: var(--border); margin: .25rem 0; }

        /* ════════════════════════════════
           CONTENT + FOOTER
        ════════════════════════════════ */
        .mch-content { flex: 1; padding: 1.75rem; }
        .mch-footer {
            padding: .875rem 1.75rem;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: .75rem;
            color: var(--label);
            background: var(--surface);
            flex-wrap: wrap;
            gap: .5rem;
        }

        /* ════════════════════════════════
           MOBILE OVERLAY
        ════════════════════════════════ */
        .mch-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,.4);
            z-index: 150;
            backdrop-filter: blur(2px);
        }
        .mch-overlay.show { display: block; }

        /* ════════════════════════════════
           RESPONSIVE
        ════════════════════════════════ */
        @@media (max-width: 991px) {
            .mch-sidebar {
                transform: translateX(-100%);
                z-index: 300;
                width: var(--sb-w) !important;
            }
            .mch-sidebar.open { transform: translateX(0); }
            .mch-wrap { margin-left: 0 !important; }
            .mch-content { padding: 1rem; }
            .mch-role-pill { display: none; }
        }
        @@media (min-width: 992px) {
            .mch-user-name { display: inline !important; }
        }

        /* ── Validation helpers ── */
        .validation-summary-valid { display: none !important; }
        .field-validation-error, .text-danger { color: #DC2626 !important; font-size: .75rem; }
        .input-validation-error { border-color: #DC2626 !important; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @* ── Sidebar ── *@
    <aside class="mch-sidebar" id="mchSidebar">

        @* Logo *@
        <a href="/" class="mch-logo">
            <span class="mch-logo-icon">🚲</span>
            <span class="mch-logo-text">BikeService</span>
            <span class="mch-logo-badge">Mechanic</span>
        </a>

        @* Navigation *@
        <nav class="mch-nav">

            <div class="mch-nav-section">
                <span class="mch-nav-label">Overview</span>
                <a class="mch-nav-item @(IsActive("Mechanic","Index") ? "active" : "")"
                   asp-controller="Mechanic" asp-action="Index" data-label="Dashboard">
                    <span class="mch-nav-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7"/>
                            <rect x="14" y="3" width="7" height="7"/>
                            <rect x="14" y="14" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/>
                        </svg>
                    </span>
                    <span class="mch-nav-text">Dashboard</span>
                </a>
            </div>

            <div class="mch-nav-section">
                <span class="mch-nav-label">Work</span>
                <a class="mch-nav-item @(IsActive("Mechanic","Tickets") ? "active" : "")"
                   asp-controller="Mechanic" asp-action="Tickets" data-label="My Tickets">
                    <span class="mch-nav-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                        </svg>
                    </span>
                    <span class="mch-nav-text">My Tickets</span>
                </a>
            </div>

            <div class="mch-nav-section">
                <span class="mch-nav-label">Leave</span>
                <a class="mch-nav-item @(IsActive("Mechanic","Leave") ? "active" : "")"
                   asp-controller="Mechanic" asp-action="Leave" data-label="My Leave">
                    <span class="mch-nav-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                    </span>
                    <span class="mch-nav-text">My Leave</span>
                </a>
                <a class="mch-nav-item @(IsActive("Mechanic","LeaveCreate") ? "active" : "")"
                   asp-controller="Mechanic" asp-action="LeaveCreate" data-label="New Request">
                    <span class="mch-nav-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="16"/>
                            <line x1="8" y1="12" x2="16" y2="12"/>
                        </svg>
                    </span>
                    <span class="mch-nav-text">New Request</span>
                </a>
            </div>

            <div class="mch-nav-section">
                <span class="mch-nav-label">Payroll</span>
                <a class="mch-nav-item @(IsActive("Mechanic","Payroll") ? "active" : "")"
                   asp-controller="Mechanic" asp-action="Payroll" data-label="My Payroll">
                    <span class="mch-nav-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="1" x2="12" y2="23"/>
                            <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                        </svg>
                    </span>
                    <span class="mch-nav-text">My Payroll</span>
                </a>
            </div>

            <div class="mch-nav-section">
                <span class="mch-nav-label">Account</span>
                <a class="mch-nav-item @(IsActive("Account","Profile") ? "active" : "")"
                   asp-controller="Account" asp-action="Profile" data-label="Profile">
                    <span class="mch-nav-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </span>
                    <span class="mch-nav-text">Profile</span>
                </a>
            </div>

        </nav>

        @* Collapse toggle *@
        <div class="mch-sidebar-foot">
            <button class="mch-collapse-btn" id="mchCollapseBtn" title="Collapse sidebar" type="button">
                <span class="mch-collapse-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </span>
                <span class="mch-collapse-text">Collapse</span>
            </button>
        </div>

    </aside>

    @* ── Main wrapper ── *@
    <div class="mch-wrap" id="mchWrap">

        @* ── Topbar ── *@
        <header class="mch-topbar">
            <div class="mch-topbar-left">
                <button class="mch-toggle-btn" id="mchToggleBtn" type="button" title="Toggle sidebar">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="6"  x2="21" y2="6"/>
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>
                <h1 class="mch-page-title">@pageTitle</h1>
                <span class="mch-role-pill">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
                    </svg>
                    Mechanic
                </span>
            </div>

            <div class="mch-topbar-right">

                @* Notification bell with live count *@
                <a asp-controller="Notification" asp-action="Index"
                   class="mch-icon-btn" title="@(unread > 0 ? $"{unread} unread notification{(unread == 1 ? "" : "s")}" : "Notifications")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                    @if (unread > 0)
                    {
                        <span class="mch-bell-count">@(unread > 99 ? "99+" : unread.ToString())</span>
                    }
                </a>

                <div class="mch-topbar-divider"></div>

                @* User dropdown *@
                <div class="mch-user-drop" id="mchUserDrop">
                    <button class="mch-user-btn" id="mchUserBtn" type="button">
                        <span class="mch-avatar">@initial</span>
                        <span class="mch-user-name">@fullName</span>
                        <span class="mch-user-caret">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                        </span>
                    </button>

                    <div class="mch-drop-menu" id="mchDropMenu">
                        <div class="mch-drop-head">
                            <div class="mch-drop-head-name">@fullName</div>
                            <div class="mch-drop-head-role">Mechanic</div>
                        </div>
                        <a asp-controller="Account" asp-action="Profile" class="mch-drop-item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            My Profile
                        </a>
                        <a asp-controller="Account" asp-action="ChangePassword" class="mch-drop-item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0110 0v4"/>
                            </svg>
                            Change Password
                        </a>
                        <div class="mch-drop-divider"></div>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
                            <button type="submit" class="mch-drop-item danger">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/>
                                    <line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                Sign Out
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </header>

        @* ── Page content ── *@
        <main class="mch-content">
            @RenderBody()
        </main>

        @* ── Footer ── *@
        <footer class="mch-footer">
            <span>&copy; @DateTime.Now.Year BikeService. All rights reserved.</span>
            <span>Mechanic Portal</span>
        </footer>

    </div>

    @* Mobile overlay *@
    <div class="mch-overlay" id="mchOverlay" onclick="mchCloseMobile()"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

    <script>
        (function () {
            var sidebar     = document.getElementById('mchSidebar');
            var wrap        = document.getElementById('mchWrap');
            var overlay     = document.getElementById('mchOverlay');
            var toggleBtn   = document.getElementById('mchToggleBtn');
            var collapseBtn = document.getElementById('mchCollapseBtn');
            var userDrop    = document.getElementById('mchUserDrop');
            var userBtn     = document.getElementById('mchUserBtn');

            var isMobile = function () { return window.innerWidth < 992; };

            // Restore mini state on desktop load
            if (!isMobile() && localStorage.getItem('mchSidebarMini') === '1') {
                sidebar && sidebar.classList.add('mini');
                wrap    && wrap.classList.add('mini');
            }

            // Topbar hamburger toggle
            if (toggleBtn) {
                toggleBtn.addEventListener('click', function () {
                    if (isMobile()) {
                        sidebar.classList.toggle('open');
                        overlay.classList.toggle('show');
                    } else {
                        sidebar.classList.toggle('mini');
                        wrap.classList.toggle('mini');
                        localStorage.setItem('mchSidebarMini', sidebar.classList.contains('mini') ? '1' : '0');
                    }
                });
            }

            // Sidebar collapse button
            if (collapseBtn) {
                collapseBtn.addEventListener('click', function () {
                    sidebar.classList.toggle('mini');
                    wrap.classList.toggle('mini');
                    localStorage.setItem('mchSidebarMini', sidebar.classList.contains('mini') ? '1' : '0');
                });
            }

            // Close mobile drawer
            window.mchCloseMobile = function () {
                sidebar && sidebar.classList.remove('open');
                overlay && overlay.classList.remove('show');
            };

            // User dropdown
            if (userBtn && userDrop) {
                userBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    userDrop.classList.toggle('open');
                });
                document.addEventListener('click', function () { userDrop.classList.remove('open'); });
                var menu = document.getElementById('mchDropMenu');
                if (menu) menu.addEventListener('click', function (e) { e.stopPropagation(); });
            }

            // Reset on resize
            window.addEventListener('resize', function () {
                if (!isMobile()) {
                    overlay && overlay.classList.remove('show');
                    sidebar && sidebar.classList.remove('open');
                } else {
                    wrap && wrap.classList.remove('mini');
                }
            });
        })();

        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({ icon: 'success', title: 'Success', text: '@Html.Raw(TempData["Success"])', timer: 2500, showConfirmButton: false, toast: true, position: 'top-end' });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({ icon: 'error', title: 'Error', text: '@Html.Raw(TempData["Error"])' });
            </text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
