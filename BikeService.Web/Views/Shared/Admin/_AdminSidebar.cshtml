@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<aside class="adm-sidebar" id="admSidebar">

    @* Logo *@
    <a href="/" class="adm-logo">
        <span class="adm-logo-icon">🚲</span>
        <span class="adm-logo-text">BikeService</span>
        <span class="adm-logo-badge">Admin</span>
    </a>

    @*Navigation *@
    <nav class="adm-nav" id="admNav">

        @*DASHBOARD *@
        <div class="adm-nav-section">
            <span class="adm-nav-label">Dashboard</span>
            <a class="adm-nav-item @(ctrl == "Analytics" ? "active" : "")"
               asp-controller="Analytics" asp-action="Index" data-label="Analytics">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Analytics</span>
            </a>
        </div>

        @*SERVICE *@
        <div class="adm-nav-section">
            <span class="adm-nav-label">Service</span>
            <a class="adm-nav-item @(ctrl == "Ticket" ? "active" : "")"
               asp-controller="Ticket" asp-action="Index" data-label="Tickets">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Tickets</span>
            </a>
            <a class="adm-nav-item @(ctrl == "AdminAppointment" ? "active" : "")"
               asp-controller="AdminAppointment" asp-action="Index" data-label="Appointments">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Appointments</span>
            </a>
            <a class="adm-nav-item @(ctrl == "ServiceType" ? "active" : "")"
               asp-controller="ServiceType" asp-action="Index" data-label="Service Types">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Service Types</span>
            </a>
        </div>

        @*INVENTORY *@
        <div class="adm-nav-section">
            <span class="adm-nav-label">Inventory</span>
            <a class="adm-nav-item @(ctrl == "Inventory" ? "active" : "")"
               asp-controller="Inventory" asp-action="Index" data-label="Parts">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                        <line x1="12" y1="22.08" x2="12" y2="12"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Parts</span>
            </a>
        </div>

        @*STAFF *@
        <div class="adm-nav-section">
            <span class="adm-nav-label">Staff</span>
            <a class="adm-nav-item @(ctrl == "AdminMechanic" ? "active" : "")"
               asp-controller="AdminMechanic" asp-action="Index" data-label="Mechanics">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Mechanics</span>
            </a>
            <a class="adm-nav-item @(ctrl == "Customer" ? "active" : "")"
               asp-controller="Customer" asp-action="Index" data-label="Customers">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                        <path d="M16 3.13a4 4 0 010 7.75"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Customers</span>
            </a>
            <a class="adm-nav-item @(ctrl == "LeaveRequest" ? "active" : "")"
               asp-controller="LeaveRequest" asp-action="Index" data-label="Leave Requests">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                        <line x1="10" y1="14" x2="14" y2="18"/>
                        <line x1="14" y1="14" x2="10" y2="18"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Leave Requests</span>
            </a>
        </div>

        @*FINANCE *@
        <div class="adm-nav-section">
            <span class="adm-nav-label">Finance</span>
            <a class="adm-nav-item @(ctrl == "AdminInvoice" ? "active" : "")"
               asp-controller="AdminInvoice" asp-action="Index" data-label="Invoices">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Invoices</span>
            </a>
            <a class="adm-nav-item @(ctrl == "PromoCode" ? "active" : "")"
               asp-controller="PromoCode" asp-action="Index" data-label="Promo Codes">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
                        <line x1="7" y1="7" x2="7.01" y2="7"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Promo Codes</span>
            </a>
            <a class="adm-nav-item @(ctrl == "PaymentGateway" ? "active" : "")"
               asp-controller="PaymentGateway" asp-action="Index" data-label="Payment Gateways">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                        <line x1="1" y1="10" x2="23" y2="10"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Payment Gateways</span>
            </a>
            <a class="adm-nav-item @(ctrl == "Payroll" ? "active" : "")"
               asp-controller="Payroll" asp-action="Index" data-label="Payroll">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23"/>
                        <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Payroll</span>
            </a>
        </div>

        @*SYSTEM *@
        <div class="adm-nav-section">
            <span class="adm-nav-label">System</span>
            <a class="adm-nav-item @(ctrl == "Report" ? "active" : "")"
               asp-controller="Report" asp-action="Index" data-label="Reports">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Reports</span>
            </a>
            <a class="adm-nav-item @(ctrl == "AuditLog" ? "active" : "")"
               asp-controller="AuditLog" asp-action="Index" data-label="Audit Logs">
                <span class="adm-nav-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </span>
                <span class="adm-nav-text">Audit Logs</span>
            </a>
        </div>

    </nav>

    @*Collapse toggle *@
    <div class="adm-sidebar-foot">
        <button class="adm-collapse-btn" id="admCollapseBtn" title="Collapse sidebar">
            <span class="adm-collapse-icon">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </span>
            <span class="adm-collapse-text">Collapse</span>
        </button>
    </div>

</aside>
