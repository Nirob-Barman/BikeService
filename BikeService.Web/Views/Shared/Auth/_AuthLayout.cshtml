<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BikeService</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ── Design tokens ── */
        :root {
            --p:        #5B4FE9;
            --p-dark:   #4338CA;
            --p-light:  #EEF2FF;
            --p-ring:   rgba(91,79,233,.15);
            --surface:  #FFFFFF;
            --bg:       #F8FAFC;
            --border:   #E2E8F0;
            --text:     #0F172A;
            --muted:    #64748B;
            --err:      #EF4444;
            --err-bg:   #FEF2F2;
            --err-ring: rgba(239,68,68,.15);
            --radius:   10px;
            --radius-sm:8px;
            --shadow:   0 1px 2px rgba(0,0,0,.05), 0 4px 16px rgba(0,0,0,.06);
            --font:     'Inter', system-ui, -apple-system, sans-serif;
            --t:        180ms ease;
            /* Override Bootstrap primary */
            --bs-primary: #5B4FE9;
            --bs-primary-rgb: 91,79,233;
            --bs-body-font-family: var(--font);
            --bs-border-radius: var(--radius-sm);
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            margin: 0;
            min-height: 100vh;
        }

        /* ── Shell: split grid ── */
        .auth-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr;
        }
        @@media (min-width: 1024px) {
            .auth-shell { grid-template-columns: 480px 1fr; }
        }

        /* ── Brand panel ── */
        .auth-brand {
            display: none;
            background: linear-gradient(150deg, #3B2FCF 0%, #5B4FE9 45%, #7C3AED 100%);
            padding: 3rem 3.5rem;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }
        @@media (min-width: 1024px) { .auth-brand { display: flex; } }

        .auth-brand::before {
            content: '';
            position: absolute;
            top: -100px; right: -100px;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: rgba(255,255,255,.055);
            pointer-events: none;
        }
        .auth-brand::after {
            content: '';
            position: absolute;
            bottom: -80px; left: -80px;
            width: 320px; height: 320px;
            border-radius: 50%;
            background: rgba(255,255,255,.04);
            pointer-events: none;
        }

        .brand-logo {
            display: inline-flex;
            align-items: center;
            gap: .7rem;
            text-decoration: none;
        }
        .brand-logo-icon {
            width: 42px; height: 42px;
            background: rgba(255,255,255,.18);
            border-radius: 11px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
        }
        .brand-logo-name {
            font-size: 1.2rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: -.025em;
        }

        .brand-body { position: relative; z-index: 1; }
        .brand-headline {
            font-size: 2.1rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: -.04em;
            line-height: 1.2;
            margin-bottom: .875rem;
        }
        .brand-sub {
            color: rgba(255,255,255,.68);
            font-size: .9375rem;
            line-height: 1.65;
            margin-bottom: 2rem;
        }
        .brand-features {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .brand-features li {
            display: flex;
            align-items: center;
            gap: .75rem;
            color: rgba(255,255,255,.82);
            font-size: .875rem;
            margin-bottom: .7rem;
        }
        .feat-check {
            width: 22px; height: 22px;
            background: rgba(255,255,255,.18);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .brand-foot {
            position: relative; z-index: 1;
            color: rgba(255,255,255,.38);
            font-size: .78rem;
        }

        /* ── Form panel ── */
        .auth-form {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2.5rem 1.5rem;
            background: var(--surface);
        }
        .auth-form-inner {
            width: 100%;
            max-width: 400px;
        }

        /* Mobile brand mark */
        .auth-mob-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            text-decoration: none;
            margin-bottom: 2.25rem;
        }
        .auth-mob-icon {
            width: 38px; height: 38px;
            background: var(--p);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.15rem;
        }
        .auth-mob-name {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--p);
            letter-spacing: -.025em;
        }
        @@media (min-width: 1024px) { .auth-mob-brand { display: none; } }

        /* ── Page title ── */
        .auth-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -.035em;
            margin-bottom: .3rem;
        }
        .auth-sub {
            color: var(--muted);
            font-size: .875rem;
            margin-bottom: 1.75rem;
        }

        /* ── Form controls ── */
        .form-label {
            font-size: .8125rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: .35rem;
        }
        .form-control {
            height: 42px;
            padding: 0 .875rem;
            font-size: .9rem;
            font-family: var(--font);
            color: var(--text);
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            transition: border-color var(--t), box-shadow var(--t);
        }
        .form-control::placeholder { color: #A8B5C5; }
        .form-control:focus {
            border-color: var(--p);
            box-shadow: 0 0 0 3px var(--p-ring);
            outline: none;
        }
        .form-control.input-validation-error,
        .form-control.is-invalid {
            border-color: var(--err);
            box-shadow: none;
        }
        .form-control.input-validation-error:focus,
        .form-control.is-invalid:focus {
            box-shadow: 0 0 0 3px var(--err-ring);
        }
        .field-validation-error,
        .text-danger.small {
            color: var(--err) !important;
            font-size: .775rem;
            margin-top: .3rem;
            display: block;
        }
        .validation-summary-valid { display: none !important; }
        .validation-summary-errors {
            background: var(--err-bg);
            border: 1px solid rgba(239,68,68,.2);
            border-radius: var(--radius-sm);
            padding: .7rem 1rem;
            margin-bottom: 1.25rem;
            font-size: .8rem;
            color: var(--err);
        }
        .validation-summary-errors ul {
            margin: 0;
            padding-left: 1.1rem;
        }

        /* ── Password wrapper ── */
        .pw-wrap { position: relative; }
        .pw-wrap .form-control { padding-right: 2.75rem; }
        .pw-toggle {
            position: absolute;
            right: .75rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
            color: var(--muted);
            display: flex;
            align-items: center;
            transition: color var(--t);
            line-height: 0;
        }
        .pw-toggle:hover { color: var(--text); }

        /* ── Password strength ── */
        .strength-row {
            display: flex;
            align-items: center;
            gap: .5rem;
            margin-top: .45rem;
        }
        .strength-track {
            flex: 1;
            height: 3px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
        }
        .strength-fill {
            height: 100%;
            width: 0;
            border-radius: 2px;
            transition: width .3s ease, background .3s ease;
        }
        .strength-text {
            font-size: .72rem;
            font-weight: 600;
            min-width: 3.2rem;
            text-align: right;
        }

        /* ── Submit button ── */
        .btn-auth {
            width: 100%;
            height: 42px;
            background: var(--p);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-family: var(--font);
            font-size: .9rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            transition: background var(--t), box-shadow var(--t), transform var(--t);
            position: relative;
            overflow: hidden;
            letter-spacing: -.01em;
        }
        .btn-auth:hover:not(:disabled) {
            background: var(--p-dark);
            box-shadow: 0 4px 14px rgba(91,79,233,.35);
            transform: translateY(-1px);
        }
        .btn-auth:active:not(:disabled) { transform: translateY(0); }
        .btn-auth:disabled { opacity: .65; cursor: not-allowed; }
        .btn-auth .spin {
            display: none;
            width: 16px; height: 16px;
            border: 2px solid rgba(255,255,255,.35);
            border-top-color: #fff;
            border-radius: 50%;
            animation: bspin .55s linear infinite;
        }
        .btn-auth.loading .spin { display: block; }
        .btn-auth.loading .lbl { opacity: 0; position: absolute; }
        @@keyframes bspin { to { transform: rotate(360deg); } }

        /* ── Alt link ── */
        .auth-alt {
            text-align: center;
            font-size: .85rem;
            color: var(--muted);
            margin-top: 1.5rem;
        }
        .auth-alt a {
            color: var(--p);
            font-weight: 600;
            text-decoration: none;
        }
        .auth-alt a:hover { text-decoration: underline; }

        /* ── Footer ── */
        .auth-page-foot {
            text-align: center;
            font-size: .775rem;
            color: #94A3B8;
            margin-top: 2.5rem;
        }
        .auth-page-foot a {
            color: #94A3B8;
            text-decoration: none;
        }
        .auth-page-foot a:hover { color: var(--muted); }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="auth-shell">

    @* Brand panel *@
    <div class="auth-brand">
        <a asp-controller="Home" asp-action="Index" class="brand-logo">
            <div class="brand-logo-icon">🚲</div>
            <span class="brand-logo-name">BikeService</span>
        </a>

        <div class="brand-body">
            <h2 class="brand-headline">Your bike deserves<br/>the best care.</h2>
            <p class="brand-sub">Book service appointments, track repairs in real time, and pay invoices securely — all in one place.</p>
            <ul class="brand-features">
                <li>
                    <div class="feat-check">
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                            <path d="M2 5l2 2 4-4" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    Real-time repair status tracking
                </li>
                <li>
                    <div class="feat-check">
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                            <path d="M2 5l2 2 4-4" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    Secure online payments
                </li>
                <li>
                    <div class="feat-check">
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                            <path d="M2 5l2 2 4-4" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    Certified expert mechanics
                </li>
            </ul>
        </div>

        <p class="brand-foot mb-0">&copy; @DateTime.Now.Year BikeService. All rights reserved.</p>
    </div>

    @* Form panel *@
    <div class="auth-form">
        <div class="auth-form-inner">

            <a asp-controller="Home" asp-action="Index" class="auth-mob-brand">
                <div class="auth-mob-icon">🚲</div>
                <span class="auth-mob-name">BikeService</span>
            </a>

            @RenderBody()

            <div class="auth-page-foot">
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>&ensp;·&ensp;<a href="#">Terms</a>&ensp;·&ensp;<a href="#">Help</a>
            </div>
        </div>
    </div>

</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    /* Shared: password visibility toggle */
    function pwToggle(inputId, btn) {
        var inp = document.getElementById(inputId);
        var showing = inp.type === 'text';
        inp.type = showing ? 'password' : 'text';
        btn.querySelector('svg').innerHTML = showing
            ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
            : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
        btn.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
    }

    /* Shared: password strength meter */
    function pwStrength(val, fillId, textId) {
        var fill = document.getElementById(fillId);
        var lbl  = document.getElementById(textId);
        if (!fill || !lbl) return;
        if (!val) { fill.style.width = '0'; lbl.textContent = ''; return; }
        var s = 0;
        if (val.length >= 6)  s++;
        if (val.length >= 10) s++;
        if (/[A-Z]/.test(val)) s++;
        if (/[0-9]/.test(val)) s++;
        if (/[^A-Za-z0-9]/.test(val)) s++;
        var map = [
            {w:'20%',c:'#EF4444',t:'Weak'},
            {w:'40%',c:'#F97316',t:'Fair'},
            {w:'60%',c:'#EAB308',t:'Good'},
            {w:'80%',c:'#22C55E',t:'Strong'},
            {w:'100%',c:'#16A34A',t:'Great!'},
        ];
        var cfg = map[Math.min(s - 1, 4)] || map[0];
        fill.style.width   = cfg.w;
        fill.style.background = cfg.c;
        lbl.textContent    = cfg.t;
        lbl.style.color    = cfg.c;
    }

    /* Shared: loading state on form submit */
    function bindSubmitLoading(formId, btnId) {
        var form = document.getElementById(formId);
        var btn  = document.getElementById(btnId);
        if (!form || !btn) return;
        form.addEventListener('submit', function () {
            btn.classList.add('loading');
            btn.disabled = true;
        });
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
