@using System.Security.Claims

<div class="d-flex justify-content-between align-items-center mb-4">

    <a asp-controller="Home" asp-action="Index" class="auth-brand">
        BikeService
    </a>

    <div class="d-flex gap-2 align-items-center">
        @if (User.Identity?.IsAuthenticated == true)
        {
            var fullName = User.FindFirstValue(ClaimTypes.Name) ?? "User";

            <span class="text-muted small">@fullName</span>

            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                <button type="submit" class="btn btn-sm btn-outline-secondary">Sign Out</button>
            </form>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login"
               class="btn btn-sm btn-outline-secondary">Sign In</a>

            <a asp-controller="Account" asp-action="Register"
               class="btn btn-sm btn-primary">Register</a>
        }
    </div>

</div>
