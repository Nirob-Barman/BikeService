@model List<BikeService.Application.DTOs.PromoCode.PromoCodeDto>
@{
    ViewData["Title"] = "Current Offers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    .offers-hero {
        text-align: center;
        padding: 3rem 0 2rem;
    }
    .offers-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: .375rem;
        background: #EEF2FF;
        color: #5B4FE9;
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        padding: .3rem .75rem;
        border-radius: 20px;
        margin-bottom: 1rem;
    }
    .offers-hero h1 {
        font-size: 2rem;
        font-weight: 800;
        color: #0F172A;
        letter-spacing: -.03em;
        margin: 0 0 .625rem;
    }
    .offers-hero p {
        color: #64748B;
        font-size: 1rem;
        margin: 0;
    }

    .offers-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        padding-bottom: 3rem;
    }
    @@media (max-width: 900px) { .offers-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 580px) { .offers-grid { grid-template-columns: 1fr; } }

    .offer-card {
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: box-shadow .2s ease, transform .2s ease;
    }
    .offer-card:hover {
        box-shadow: 0 8px 24px rgba(91,79,233,.1);
        transform: translateY(-2px);
    }
    .offer-card-top {
        background: linear-gradient(135deg, #5B4FE9 0%, #7C3AED 100%);
        padding: 1.75rem 1.5rem 1.5rem;
        position: relative;
        overflow: hidden;
        text-align: center;
    }
    .offer-card-top::before {
        content: '';
        position: absolute;
        top: -30px; right: -30px;
        width: 100px; height: 100px;
        background: rgba(255,255,255,.08);
        border-radius: 50%;
    }
    .offer-card-top::after {
        content: '';
        position: absolute;
        bottom: -20px; left: -20px;
        width: 80px; height: 80px;
        background: rgba(255,255,255,.06);
        border-radius: 50%;
    }
    .offer-discount {
        font-size: 3rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -.04em;
        line-height: 1;
        position: relative;
        z-index: 1;
    }
    .offer-discount span {
        font-size: 1.25rem;
        font-weight: 700;
        vertical-align: super;
        margin-right: .1rem;
    }
    .offer-discount-sub {
        font-size: .8125rem;
        color: rgba(255,255,255,.75);
        margin-top: .25rem;
        position: relative;
        z-index: 1;
    }

    .offer-card-body {
        padding: 1.25rem 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .offer-code-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        background: #F8FAFC;
        border: 1.5px dashed #CBD5E1;
        border-radius: 8px;
        padding: .625rem .875rem;
    }
    .offer-code {
        flex: 1;
        font-family: 'Courier New', monospace;
        font-size: 1rem;
        font-weight: 700;
        color: #0F172A;
        letter-spacing: .08em;
    }
    .offer-copy-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
        height: 28px;
        padding: 0 .625rem;
        border: none;
        border-radius: 6px;
        background: #5B4FE9;
        color: #fff;
        font-size: .75rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s ease;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .offer-copy-btn:hover { background: #4338CA; }
    .offer-copy-btn.copied { background: #16A34A; }

    .offer-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: .8125rem;
    }
    .offer-expiry {
        color: #64748B;
        display: flex;
        align-items: center;
        gap: .3rem;
    }
    .offer-stock {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: #FEF3C7;
        color: #D97706;
        font-size: .6875rem;
        font-weight: 700;
        padding: .2rem .5rem;
        border-radius: 20px;
    }

    .offer-cta {
        display: block;
        text-align: center;
        padding: .7rem;
        background: #EEF2FF;
        color: #5B4FE9;
        font-size: .8375rem;
        font-weight: 600;
        border-top: 1.5px solid #E2E8F0;
        text-decoration: none;
        transition: background .15s ease;
    }
    .offer-cta:hover { background: #E0E7FF; color: #4338CA; text-decoration: none; }

    .offers-empty {
        text-align: center;
        padding: 4rem 1rem;
    }
    .offers-empty-icon {
        width: 64px; height: 64px;
        background: #F1F5F9;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
        color: #94A3B8;
    }
    .offers-empty h4 {
        font-size: 1.0625rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 .375rem;
    }
    .offers-empty p {
        color: #64748B;
        font-size: .9rem;
        margin: 0 0 1.25rem;
    }
</style>
}

<div class="offers-hero">
    <div class="offers-hero-badge">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 12 20 22 4 22 4 12"/>
            <rect x="2" y="7" width="20" height="5"/>
            <line x1="12" y1="22" x2="12" y2="7"/>
            <path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/>
            <path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/>
        </svg>
        Limited-Time Offers
    </div>
    <h1>Current Promotions</h1>
    <p>Use a promo code at checkout to save on your next service</p>
</div>

@if (!Model.Any())
{
    <div class="offers-empty">
        <div class="offers-empty-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
                <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
        </div>
        <h4>No active offers right now</h4>
        <p>Check back soon — new promotions are added regularly.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-sm">Back to Home</a>
    </div>
}
else
{
    <div class="offers-grid">
        @foreach (var promo in Model)
        {
            <div class="offer-card">
                <div class="offer-card-top">
                    <div class="offer-discount"><span>%</span>@promo.DiscountPercent</div>
                    <div class="offer-discount-sub">discount on any service</div>
                </div>
                <div class="offer-card-body">
                    <div class="offer-code-row">
                        <span class="offer-code" id="code-@promo.Id">@promo.Code</span>
                        <button class="offer-copy-btn" onclick="copyCode('@promo.Code', this)">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                            </svg>
                            Copy
                        </button>
                    </div>
                    <div class="offer-meta">
                        <span class="offer-expiry">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            @if (promo.ExpiresAt.HasValue)
                            {
                                <span>Expires @promo.ExpiresAt.Value.ToString("MMM d, yyyy")</span>
                            }
                            else
                            {
                                <span>No expiry</span>
                            }
                        </span>
                        @if (promo.RemainingUsages <= 5 && promo.RemainingUsages > 0)
                        {
                            <span class="offer-stock">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                                </svg>
                                @promo.RemainingUsages left
                            </span>
                        }
                    </div>
                </div>
                <a asp-controller="Appointment" asp-action="Create" class="offer-cta">
                    Book &amp; Use This Code
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:.25rem;">
                        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
            </div>
        }
    </div>
}

@section Scripts {
<script>
    function copyCode(code, btn) {
        navigator.clipboard.writeText(code).then(function () {
            var orig = btn.innerHTML;
            btn.classList.add('copied');
            btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied';
            setTimeout(function () {
                btn.classList.remove('copied');
                btn.innerHTML = orig;
            }, 2000);
        });
    }
</script>
}
