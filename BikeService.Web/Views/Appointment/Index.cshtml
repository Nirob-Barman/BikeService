@model List<BikeService.Application.DTOs.Appointment.AppointmentDto>
@using BikeService.Domain.Enums
@{
    ViewData["Title"] = "My Appointments";
}

<div class="cst-page-head">
    <div class="cst-page-head-left">
        <h2>My Appointments</h2>
        @if (Model.Any())
        {
            <span class="cst-badge cst-badge-pending">@Model.Count total</span>
        }
    </div>
    <a asp-action="Create" class="cst-btn cst-btn-primary">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Book Appointment
    </a>
</div>

@if (!Model.Any())
{
    <div class="cst-card">
        <div class="cst-empty">
            <div class="cst-empty-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <h4>No appointments yet</h4>
            <p>Schedule a visit and we'll get your bike sorted out.</p>
            <a asp-action="Create" class="cst-btn cst-btn-primary">Book an Appointment</a>
        </div>
    </div>
}
else
{
    <div class="cst-card">
        <div class="cst-table-wrap">
            <table class="cst-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Bike</th>
                        <th>Date &amp; Time</th>
                        <th>Notes</th>
                        <th>Status</th>
                        <th class="r"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appt in Model.OrderByDescending(a => a.AppointmentDate))
                    {
                        <tr>
                            <td class="muted">#@appt.Id</td>
                            <td class="bold">@appt.BikeSummary</td>
                            <td>@appt.AppointmentDate.ToString("MMM d, yyyy h:mm tt")</td>
                            <td class="muted">@(appt.Notes ?? "—")</td>
                            <td>
                                @{
                                    var (aBadge, aLbl) = appt.Status switch
                                    {
                                        AppointmentStatus.Scheduled => ("cst-badge-warning", "Scheduled"),
                                        AppointmentStatus.Confirmed => ("cst-badge-success", "Confirmed"),
                                        AppointmentStatus.Completed => ("cst-badge-primary", "Completed"),
                                        AppointmentStatus.Cancelled => ("cst-badge-pending", "Cancelled"),
                                        _                           => ("cst-badge-pending", appt.StatusLabel)
                                    };
                                }
                                <span class="cst-badge @aBadge">@aLbl</span>
                            </td>
                            <td class="r">
                                @if (appt.Status == AppointmentStatus.Scheduled)
                                {
                                    <form asp-action="Cancel" asp-route-id="@appt.Id" method="post"
                                          onsubmit="return confirm('Cancel this appointment?')"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="cst-btn cst-btn-danger cst-btn-sm">Cancel</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
