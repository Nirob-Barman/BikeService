@model BikeService.Application.DTOs.Payroll.PayrollRecordDto
@using BikeService.Domain.Enums
@{
    ViewData["Title"] = $"Payroll — {Model.MechanicName} ({Model.PeriodLabel})";
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Payroll Detail</h4>
        <small class="text-muted">@Model.MechanicName — @Model.PeriodLabel</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row g-4">
    <!-- Summary card -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:64px;height:64px;">
                    <i class="bi bi-person-fill text-primary fs-3"></i>
                </div>
                <h5 class="fw-bold mb-0">@Model.MechanicName</h5>
                <p class="text-muted mb-3">@Model.PeriodLabel</p>

                @{
                    var (badgeClass, label) = Model.Status switch
                    {
                        PayrollStatus.Draft     => ("bg-secondary", "Draft"),
                        PayrollStatus.Finalized => ("bg-primary",   "Finalized"),
                        PayrollStatus.Paid      => ("bg-success",   "Paid"),
                        _                       => ("bg-secondary", Model.Status.ToString())
                    };
                }
                <span class="badge @badgeClass fs-6 px-3 py-2">@label</span>

                <hr class="my-3" />
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Created</span>
                    <span>@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Breakdown -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold">Salary Breakdown</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Base Salary</dt>
                    <dd class="col-sm-8 fw-semibold">৳@Model.BaseSalary.ToString("N2")</dd>

                    <dt class="col-sm-4">Bonus</dt>
                    <dd class="col-sm-8 text-success fw-semibold">+ ৳@Model.Bonus.ToString("N2")</dd>

                    <dt class="col-sm-4">Deductions</dt>
                    <dd class="col-sm-8 text-danger fw-semibold">- ৳@Model.Deductions.ToString("N2")</dd>

                    <dt class="col-sm-4 border-top pt-2">Net Pay</dt>
                    <dd class="col-sm-8 border-top pt-2 fw-bold fs-5 text-primary">৳@Model.NetPay.ToString("N2")</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">Notes</div>
                <div class="card-body">
                    <p class="mb-0 text-muted">@Model.Notes</p>
                </div>
            </div>
        }

        <!-- Actions -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">Actions</div>
            <div class="card-body d-flex flex-wrap gap-2">
                @if (Model.Status == PayrollStatus.Draft)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>

                    <form asp-action="Finalize" asp-route-id="@Model.Id" method="post"
                          data-confirm="Finalize this payroll record? It cannot be edited after finalization.">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i> Finalize
                        </button>
                    </form>

                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                          data-confirm="Permanently delete this payroll record?">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-trash me-1"></i> Delete
                        </button>
                    </form>
                }
                else if (Model.Status == PayrollStatus.Finalized)
                {
                    <form asp-action="MarkPaid" asp-route-id="@Model.Id" method="post"
                          data-confirm="Mark this payroll as paid?">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-cash-coin me-1"></i> Mark as Paid
                        </button>
                    </form>
                }
                else
                {
                    <span class="text-muted fst-italic">No further actions — this record is Paid.</span>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('form[data-confirm]').forEach(form => {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            const msg = this.dataset.confirm;
            Swal.fire({
                title: 'Are you sure?',
                text: msg,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0d6efd',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, proceed'
            }).then(result => { if (result.isConfirmed) form.submit(); });
        });
    });
</script>
}
