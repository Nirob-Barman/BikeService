@model List<BikeService.Application.DTOs.Payroll.PayrollRecordDto>
@using BikeService.Domain.Enums
@{
    ViewData["Title"] = "Payroll Records";
    int? year = ViewBag.Year;
    int currentYear = ViewBag.CurrentYear;
}

<div class="adm-page-head">
    <div>
        <h1 class="adm-page-head-title">Payroll Records</h1>
        <p class="adm-page-head-sub">Manage mechanic salary and compensation records</p>
    </div>
    <a asp-action="Create" class="adm-btn adm-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="margin-right:.375rem;vertical-align:-.1em;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        New Record
    </a>
</div>

<div class="adm-card" style="margin-bottom:1rem;">
    <div class="adm-card-body" style="padding:.875rem 1.25rem;">
        <form method="get" style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;">
            <label class="adm-label" style="margin-bottom:0;">Year</label>
            <select name="year" class="adm-input adm-select" style="width:120px;" onchange="this.form.submit()">
                <option value="">All Years</option>
                @for (int y = currentYear; y >= currentYear - 5; y--)
                {
                    <option value="@y" selected="@(year == y ? "selected" : null)">@y</option>
                }
            </select>
            @if (year.HasValue)
            {
                <a href="@Url.Action("Index")" class="adm-btn adm-btn-secondary adm-btn-sm">Clear</a>
            }
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="adm-card">
        <div class="adm-card-body">
            <div class="adm-empty">
                <div class="adm-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
                    </svg>
                </div>
                <p class="adm-empty-title">No payroll records@(year.HasValue ? $" for {year}" : "")</p>
                <p class="adm-empty-sub">Create a payroll record to track mechanic compensation.</p>
                <a asp-action="Create" class="adm-btn adm-btn-primary" style="margin-top:1rem;">Create First Record</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="adm-card">
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Mechanic</th>
                        <th>Period</th>
                        <th style="text-align:right;">Base Salary</th>
                        <th style="text-align:right;">Bonus</th>
                        <th style="text-align:right;">Deductions</th>
                        <th style="text-align:right;">Net Pay</th>
                        <th>Status</th>
                        <th style="text-align:right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td style="font-weight:600;">@r.MechanicName</td>
                            <td>@r.PeriodLabel</td>
                            <td style="text-align:right;">৳@r.BaseSalary.ToString("N2")</td>
                            <td style="text-align:right;color:var(--success);">৳@r.Bonus.ToString("N2")</td>
                            <td style="text-align:right;color:var(--danger);">৳@r.Deductions.ToString("N2")</td>
                            <td style="text-align:right;font-weight:700;">৳@r.NetPay.ToString("N2")</td>
                            <td>
                                @{
                                    var (badgeCls, label) = r.Status switch
                                    {
                                        PayrollStatus.Draft     => ("neutral",  "Draft"),
                                        PayrollStatus.Finalized => ("primary",  "Finalized"),
                                        PayrollStatus.Paid      => ("success",  "Paid"),
                                        _                       => ("neutral",  r.Status.ToString())
                                    };
                                }
                                <span class="adm-badge @badgeCls">@label</span>
                            </td>
                            <td style="text-align:right;">
                                <a asp-action="Detail" asp-route-id="@r.Id" class="adm-btn adm-btn-secondary adm-btn-sm">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
