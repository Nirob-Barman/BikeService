@using BikeService.Application.DTOs.Appointment
@using BikeService.Domain.Enums
@model List<AppointmentDto>
@{
    ViewData["Title"] = "Appointments";

    string GetStatusBadge(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Scheduled => "neutral",
        AppointmentStatus.Confirmed => "primary",
        AppointmentStatus.Completed => "success",
        AppointmentStatus.Cancelled => "danger",
        _ => "neutral"
    };
}

<div class="adm-page-head">
    <div>
        <h1 class="adm-page-head-title">Appointments</h1>
        <p class="adm-page-head-sub">@Model.Count result(s)</p>
    </div>
</div>

<div class="adm-card" style="margin-bottom:1rem;">
    <div class="adm-card-body" style="padding:.875rem 1.25rem;">
        <form method="get" style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end;">
            <div>
                <label class="adm-label">Status</label>
                <select name="status" class="adm-input adm-select" style="width:160px;">
                    <option value="">All Statuses</option>
                    @foreach (AppointmentStatus s in Enum.GetValues(typeof(AppointmentStatus)))
                    {
                        <option value="@s" selected="@(ViewBag.StatusFilter?.ToString() == s.ToString() ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div>
                <label class="adm-label">Date From</label>
                <input type="date" name="dateFrom" class="adm-input" value="@ViewBag.DateFrom" style="width:160px;" />
            </div>
            <div>
                <label class="adm-label">Date To</label>
                <input type="date" name="dateTo" class="adm-input" value="@ViewBag.DateTo" style="width:160px;" />
            </div>
            <div style="display:flex;gap:.5rem;align-items:flex-end;">
                <button type="submit" class="adm-btn adm-btn-primary adm-btn-sm">Filter</button>
                <a href="@Url.Action("Index")" class="adm-btn adm-btn-secondary adm-btn-sm">Reset</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="adm-card">
        <div class="adm-card-body">
            <div class="adm-empty">
                <div class="adm-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                    </svg>
                </div>
                <p class="adm-empty-title">No appointments found</p>
                <p class="adm-empty-sub">Try adjusting your filters, or appointments will appear here once customers book.</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="adm-card">
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Bike</th>
                        <th>Customer</th>
                        <th>Date & Time</th>
                        <th>Status</th>
                        <th style="text-align:right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appt in Model)
                    {
                        <tr>
                            <td style="font-weight:500;">@appt.BikeSummary</td>
                            <td style="color:var(--muted);">@appt.CustomerName</td>
                            <td style="color:var(--muted);font-size:.8125rem;white-space:nowrap;">@appt.AppointmentDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td><span class="adm-badge @GetStatusBadge(appt.Status)">@appt.StatusLabel</span></td>
                            <td style="text-align:right;">
                                <a href="@Url.Action("Detail", new { id = appt.Id })" class="adm-btn adm-btn-secondary adm-btn-sm">Detail</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
