@{
    ViewData["Title"] = "Payment Cancelled";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div style="font-size:4rem;" class="mb-3 text-muted">&#8856;</div>
            <h3 class="fw-bold mb-2">Payment Cancelled</h3>
            <p class="text-muted">Your payment was cancelled. Your invoice is still open if you'd like to try again.</p>
            <div class="mt-4">
                <a asp-controller="Invoice" asp-action="Index" class="btn btn-primary">My Invoices</a>
            </div>
        </div>
    </div>
</div>
