@using BikeService.Web.ViewModels.Payment
@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    var info = Model.Info;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <h4 class="fw-bold mb-4">Complete Your Payment</h4>

            <div class="row g-4">

                @* Left: Order Summary *@
                <div class="col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-header fw-semibold bg-dark text-white">Order Summary</div>
                        <div class="card-body">
                            <p class="text-muted small mb-3">@info.BikeSummary</p>
                            <table class="table table-sm mb-0">
                                <tr>
                                    <td>Subtotal</td>
                                    <td class="text-end">৳@info.TotalAmount.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td>Tax (15%)</td>
                                    <td class="text-end">৳@info.TaxAmount.ToString("N2")</td>
                                </tr>
                                @if (info.DiscountAmount > 0)
                                {
                                    <tr class="text-success">
                                        <td>Promo (@info.AppliedPromoCode, @info.PromoDiscountPercent%)</td>
                                        <td class="text-end">-৳@info.DiscountAmount.ToString("N2")</td>
                                    </tr>
                                }
                                <tr class="fw-bold border-top">
                                    <td>Total</td>
                                    <td class="text-end fs-5">৳@info.FinalAmount.ToString("N2")</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>

                @* Right: Payment Form *@
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header fw-semibold bg-dark text-white">Payment Method</div>
                        <div class="card-body">

                            @* Promo code preview *@
                            <form method="get" asp-action="Checkout" class="mb-3">
                                <input type="hidden" name="invoiceId" value="@info.InvoiceId" />
                                <label class="form-label small fw-semibold">Promo Code</label>
                                <div class="input-group input-group-sm">
                                    <input type="text" name="promoCode" class="form-control"
                                           placeholder="Enter code" value="@Model.PromoCode" />
                                    <button type="submit" class="btn btn-outline-secondary">Apply</button>
                                </div>
                                @if (!string.IsNullOrEmpty(info.AppliedPromoCode))
                                {
                                    <div class="text-success small mt-1">
                                        ✓ Code "@info.AppliedPromoCode" applied — @info.PromoDiscountPercent% off
                                    </div>
                                }
                            </form>

                            @* Main checkout form *@
                            <form asp-action="Initiate" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="Info.InvoiceId" />
                                <input type="hidden" asp-for="PromoCode" value="@Model.PromoCode" />

                                <label class="form-label small fw-semibold">Select Gateway</label>
                                <div class="list-group mb-3">
                                    @if (!info.Gateways.Any())
                                    {
                                        <div class="alert alert-warning small">No payment gateways are active.</div>
                                    }
                                    @foreach (var gw in info.Gateways)
                                    {
                                        <label class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2">
                                            <input type="radio" asp-for="GatewayId" value="@gw.Id"
                                                   class="form-check-input mt-0" />
                                            <span>
                                                <strong>@gw.Name</strong>
                                                @if (gw.IsSandbox)
                                                {
                                                    <span class="badge bg-warning text-dark ms-1 small">Sandbox</span>
                                                }
                                            </span>
                                        </label>
                                    }
                                </div>
                                <span asp-validation-for="GatewayId" class="text-danger small d-block mb-2"></span>

                                <button type="submit" class="btn btn-primary w-100"
                                        @(info.Gateways.Any() ? "" : "disabled")>
                                    Pay ৳@info.FinalAmount.ToString("N2")
                                </button>
                            </form>

                        </div>
                    </div>
                </div>

            </div>

            <div class="mt-3">
                <a asp-controller="Invoice" asp-action="Detail" asp-route-id="@info.InvoiceId"
                   class="text-muted small">&#8592; Back to Invoice</a>
            </div>

        </div>
    </div>
</div>
