@model List<BikeService.Application.DTOs.ServiceType.ServiceTypeDto>
@{
    ViewData["Title"] = "Service Types";
}

<div class="adm-page-head">
    <div>
        <h1 class="adm-page-head-title">Service Types</h1>
        <p class="adm-page-head-sub">Define the repair and maintenance services your shop offers</p>
    </div>
    <a asp-controller="ServiceType" asp-action="Create" class="adm-btn adm-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="margin-right:.375rem;vertical-align:-.1em;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Add Service Type
    </a>
</div>

@if (!Model.Any())
{
    <div class="adm-card">
        <div class="adm-card-body">
            <div class="adm-empty">
                <div class="adm-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
                    </svg>
                </div>
                <p class="adm-empty-title">No service types yet</p>
                <p class="adm-empty-sub">Add service types to let customers book specific repair services.</p>
                <a asp-controller="ServiceType" asp-action="Create" class="adm-btn adm-btn-primary" style="margin-top:1rem;">Add First Service Type</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="adm-card">
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Base Price</th>
                        <th>Est. Hours</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="color:var(--muted);font-size:.8125rem;">@item.Id</td>
                            <td style="font-weight:500;">@item.Name</td>
                            <td style="color:var(--muted);font-size:.8125rem;max-width:220px;white-space:normal;">
                                @(item.Description?.Length > 70 ? item.Description[..70] + "…" : item.Description ?? "—")
                            </td>
                            <td>৳@item.BasePrice.ToString("0.00")</td>
                            <td>@item.EstimatedHours h</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="adm-badge success">Active</span>
                                }
                                else
                                {
                                    <span class="adm-badge neutral">Inactive</span>
                                }
                            </td>
                            <td style="color:var(--muted);font-size:.8125rem;">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td style="text-align:right;">
                                <div style="display:inline-flex;gap:.375rem;">
                                    <a asp-controller="ServiceType" asp-action="Edit" asp-route-id="@item.Id"
                                       class="adm-btn adm-btn-secondary adm-btn-sm">Edit</a>

                                    <form asp-controller="ServiceType" asp-action="Toggle" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="adm-btn adm-btn-sm @(item.IsActive ? "adm-btn-secondary" : "adm-btn-primary")">
                                            @(item.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>

                                    <form asp-controller="ServiceType" asp-action="Delete" asp-route-id="@item.Id" method="post" class="del-form" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="adm-btn adm-btn-danger adm-btn-sm del-btn" data-name="@item.Name">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
document.querySelectorAll('.del-btn').forEach(btn => {
    btn.addEventListener('click', function () {
        const name = this.dataset.name;
        const form = this.closest('.del-form');
        Swal.fire({
            title: 'Delete service type?',
            html: `<strong>${name}</strong> will be permanently deleted.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#DC2626',
            confirmButtonText: 'Delete'
        }).then(r => { if (r.isConfirmed) form.submit(); });
    });
});
</script>
}
