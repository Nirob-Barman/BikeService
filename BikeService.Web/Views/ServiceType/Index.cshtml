@model List<BikeService.Application.DTOs.ServiceType.ServiceTypeDto>
@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Service Types";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Service Types</h4>
    <a asp-controller="ServiceType" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Service Type
    </a>
</div>

@Html.AntiForgeryToken()

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <p class="mb-0">No service types found. <a asp-controller="ServiceType" asp-action="Create">Add one now.</a></p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Base Price</th>
                            <th>Est. Hours</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td class="fw-medium">@item.Name</td>
                                <td class="text-muted small">@(item.Description?.Length > 60 ? item.Description[..60] + "…" : item.Description ?? "—")</td>
                                <td>$@item.BasePrice.ToString("0.00")</td>
                                <td>@item.EstimatedHours h</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-muted small">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-end">
                                    <a asp-controller="ServiceType" asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary me-1">Edit</a>

                                    <form asp-controller="ServiceType" asp-action="Toggle" asp-route-id="@item.Id"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success") me-1">
                                            @(item.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>

                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="confirmDelete('@Url.Action("Delete", "AdminServiceType", new { id = item.Id })')">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
function confirmDelete(url) {
    Swal.fire({
        title: 'Delete Service Type?',
        text: 'This cannot be undone.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'Delete'
    }).then(r => {
        if (r.isConfirmed) {
            var f = document.createElement('form');
            f.method = 'POST';
            f.action = url;
            var t = document.createElement('input');
            t.type = 'hidden';
            t.name = '__RequestVerificationToken';
            t.value = document.querySelector('input[name=__RequestVerificationToken]')?.value || '';
            f.appendChild(t);
            document.body.appendChild(f);
            f.submit();
        }
    });
}
</script>
}
