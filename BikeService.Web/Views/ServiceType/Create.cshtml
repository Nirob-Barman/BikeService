@model BikeService.Web.ViewModels.ServiceType.ServiceTypeFormViewModel
@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Create Service Type";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Create Service Type</h4>
    <a asp-controller="ServiceType" asp-action="Index" class="btn btn-outline-secondary">
        &larr; Back to List
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 640px;">
    <div class="card-body p-4">
        <form asp-controller="ServiceType" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-medium"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Full Tune-Up" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-medium"></label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Optional description of this service"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label asp-for="BasePrice" class="form-label fw-medium"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="BasePrice" class="form-control" type="number" step="0.01" min="0.01" />
                    </div>
                    <span asp-validation-for="BasePrice" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="EstimatedHours" class="form-label fw-medium"></label>
                    <div class="input-group">
                        <input asp-for="EstimatedHours" class="form-control" type="number" step="0.1" min="0.1" />
                        <span class="input-group-text">hrs</span>
                    </div>
                    <span asp-validation-for="EstimatedHours" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active (visible to customers)</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Create</button>
                <a asp-controller="ServiceType" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
