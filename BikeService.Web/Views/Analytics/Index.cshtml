@using BikeService.Application.DTOs.Dashboard
@model DashboardDto
@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="mb-0 fw-semibold">Analytics Dashboard</h4>
    <small class="text-muted">All-time data</small>
</div>

@if (Model is null)
{
    <div class="alert alert-warning">Dashboard data could not be loaded.</div>
    return;
}

@* ── KPI Cards ── *@
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3 fs-4">💰</div>
                <div>
                    <div class="small text-muted">Total Revenue</div>
                    <div class="fs-5 fw-bold text-success">$@Model.TotalRevenue.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 fs-4">📅</div>
                <div>
                    <div class="small text-muted">Revenue This Month</div>
                    <div class="fs-5 fw-bold text-primary">$@Model.RevenueThisMonth.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3 fs-4">🔧</div>
                <div>
                    <div class="small text-muted">Tickets Today</div>
                    <div class="fs-5 fw-bold">@Model.TicketsToday</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3 fs-4">⏳</div>
                <div>
                    <div class="small text-muted">Pending Tickets</div>
                    <div class="fs-5 fw-bold text-danger">@Model.PendingTickets</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3 fs-4">⚡</div>
                <div>
                    <div class="small text-muted">Active Tickets</div>
                    <div class="fs-5 fw-bold text-info">@Model.ActiveTickets</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-secondary bg-opacity-10 p-3 fs-4">👥</div>
                <div>
                    <div class="small text-muted">Total Customers</div>
                    <div class="fs-5 fw-bold">@Model.TotalCustomers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-dark bg-opacity-10 p-3 fs-4">🚲</div>
                <div>
                    <div class="small text-muted">Total Bikes</div>
                    <div class="fs-5 fw-bold">@Model.TotalBikes</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Monthly Revenue Chart ── *@
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Monthly Revenue (Last 12 Months)</div>
            <div class="card-body">
                <canvas id="revenueChart" height="100"></canvas>
            </div>
        </div>
    </div>

    @* ── Top Mechanics ── *@
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Top Mechanics</div>
            <div class="card-body p-0">
                @if (!Model.TopMechanics.Any())
                {
                    <p class="text-muted small p-3 mb-0">No data yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var (m, i) in Model.TopMechanics.Select((m, i) => (m, i)))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    <span class="badge bg-secondary me-2">@(i + 1)</span>
                                    @m.MechanicName
                                </span>
                                <span class="badge bg-primary rounded-pill">@m.TicketsCompleted tickets</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@* ── Top Services ── *@
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold">Top Services</div>
    <div class="card-body p-0">
        @if (!Model.TopServices.Any())
        {
            <p class="text-muted small p-3 mb-0">No data yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Service</th>
                            <th class="text-end">Times Used</th>
                            <th class="text-end">Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (s, i) in Model.TopServices.Select((s, i) => (s, i)))
                        {
                            <tr>
                                <td class="text-muted">@(i + 1)</td>
                                <td>@s.ServiceName</td>
                                <td class="text-end">@s.Count</td>
                                <td class="text-end fw-medium text-success">$@s.Revenue.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenue.Select(m => m.Month)));
    const data   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenue.Select(m => m.Revenue)));

    new Chart(document.getElementById('revenueChart'), {
        type: 'bar',
        data: {
            labels,
            datasets: [{
                label: 'Revenue ($)',
                data,
                backgroundColor: 'rgba(13,110,253,0.15)',
                borderColor: 'rgba(13,110,253,0.8)',
                borderWidth: 2,
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { callback: v => '$' + v.toLocaleString() }
                }
            }
        }
    });
</script>
}
